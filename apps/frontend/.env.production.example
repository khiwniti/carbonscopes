# Frontend Application URLs
NEXT_PUBLIC_APP_URL=https://your-app-domain.com
NEXT_PUBLIC_URL=https://your-app-domain.com

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend API
NEXT_PUBLIC_BACKEND_URL=https://api.your-domain.com/v1
NEXT_PUBLIC_API_URL=https://api.your-domain.com/v1

# NextAuth Configuration
NEXTAUTH_URL=https://your-app-domain.com
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Environment & Feature Flags
NEXT_PUBLIC_ENV_MODE=production
NEXT_PUBLIC_DISABLE_MOBILE_ADVERTISING=false

# Analytics & Monitoring (optional)
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
NEXT_PUBLIC_SENTRY_DSN=

# Third-party Services (optional)
NEXT_PUBLIC_NOVU_APP_IDENTIFIER=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_PHONE_NUMBER_MANDATORY=false
NEXT_PUBLIC_VERBOSE_LOGGING=false

# Database
DATABASE_URL=postgresql://user:password@localhost/dbname
