#
# TREES NC 1.1 (Thai Rating of Energy and Environmental Sustainability - New Construction) Ontology
#
# Purpose: RDF/RDFS schema for TREES NC 1.1 green building certification
# Namespace: http://tgbi.or.th/trees/ontology#
# Version: 1.1
# Created: 2026-03-23
# License: Open for TREES certified projects
#
# TREES Certification Overview:
#   - TREES = Thai Rating of Energy and Environmental Sustainability
#   - Developed by TGBI (Thai Green Building Institute / สถาบันอาคารเขียว แห่งประเทศไทย)
#   - Thailand's premier green building certification system
#   - TREES NC = New Construction rating system
#   - Website: https://tgbi.or.th
#
# TREES NC 1.1 Certification Levels:
#   - Certified: 50-59 points
#   - Gold: 60-79 points
#   - Platinum: 80-100 points
#
# Rating Categories:
#   - Site & Landscape (SL): Max 9 points
#   - Water Efficiency (WE): Max 12 points
#   - Energy & Atmosphere (EA): Max 32 points
#   - Materials & Resources (MR): Max 15 points
#   - Indoor Environmental Quality (IEQ): Max 16 points
#   - Environmental Management (EM): Max 10 points
#   - Green Innovation (GI): Max 6 points
#   - Total: 100 points
#
# Materials & Resources (MR) Focus:
#   - MR1: Green/Carbon Labeled Materials (30% by cost, max 10 points)
#     * TGO Carbon Label, Thai Green Label, FSC, Cradle to Cradle, etc.
#   - MR3: Reused Materials (5-10% by cost, max 5 points)
#     * Salvaged, reclaimed, refurbished components
#
# Integration with TGO:
#   - Links to TGO materials for green label verification
#   - Uses TGO emission factors for carbon calculations
#   - Supports Thai construction standards
#
# GraphDB Repository: carbonbim-thailand (RDFS inference enabled)
#

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix trees: <http://tgbi.or.th/trees/ontology#> .
@prefix tgo: <http://tgo.or.th/ontology#> .

#
# Ontology Metadata
#

<http://tgbi.or.th/trees/ontology>
    rdf:type owl:Ontology ;
    dcterms:title "TREES NC 1.1 Green Building Certification Ontology"@en ;
    dcterms:title "ออนโทโลยีมาตรฐานอาคารเขียว TREES NC 1.1"@th ;
    dcterms:description "RDF schema for TREES (Thai Rating of Energy and Environmental Sustainability) NC 1.1 certification for new construction. Focuses on Materials & Resources (MR) criteria including green-labeled materials and reused materials. Integrates with TGO material database for Thai construction projects."@en ;
    dcterms:description "โครงร่างข้อมูล RDF สำหรับมาตรฐาน TREES (ระบบการประเมินอาคารเขียวของประเทศไทย) NC 1.1 สำหรับอาคารใหม่ เน้นหมวดวัสดุและทรัพยากร (MR) รวมถึงวัสดุที่มีฉลากสิ่งแวดล้อมและวัสดุนำกลับมาใช้ใหม่ ผสานกับฐานข้อมูลวัสดุ TGO สำหรับโครงการก่อสร้างในประเทศไทย"@th ;
    dcterms:creator "carbonscope BIM Platform" ;
    dcterms:created "2026-03-23"^^xsd:date ;
    dcterms:modified "2026-03-23"^^xsd:date ;
    owl:versionInfo "1.1" ;
    owl:imports <http://tgo.or.th/ontology> ;
    rdfs:comment "TREES NC 1.1 provides a point-based certification system for sustainable buildings in Thailand. This ontology enables automated compliance checking, point calculation, and materials recommendation. Initial focus on Materials & Resources (MR) category with MR1 (green-labeled materials) and MR3 (reused materials) criteria."@en ;
    rdfs:seeAlso <https://tgbi.or.th> .


#
# Core Class Hierarchy - Certification Levels
#

trees:Certification
    rdf:type rdfs:Class ;
    rdfs:label "TREES Certification"@en ;
    rdfs:label "การรับรอง TREES"@th ;
    rdfs:comment "Base class for TREES certification instances. Represents a complete certification assessment for a building project using the TREES NC 1.1 rating system."@en ;
    rdfs:comment "คลาสหลักสำหรับการรับรอง TREES แสดงถึงการประเมินมาตรฐานที่สมบูรณ์สำหรับโครงการอาคาร โดยใช้ระบบการประเมิน TREES NC 1.1"@th .

trees:Certified
    rdf:type rdfs:Class ;
    rdfs:subClassOf trees:Certification ;
    rdfs:label "TREES Certified"@en ;
    rdfs:label "TREES Certified"@th ;
    rdfs:comment "TREES Certified level. Requires minimum 50 points and maximum 59 points. This is the entry-level TREES certification demonstrating basic green building practices."@en ;
    rdfs:comment "ระดับ TREES Certified ต้องการคะแนนขั้นต่ำ 50 คะแนนและสูงสุด 59 คะแนน เป็นระดับเริ่มต้นของการรับรอง TREES ที่แสดงถึงการปฏิบัติอาคารเขียวขั้นพื้นฐาน"@th .

trees:Gold
    rdf:type rdfs:Class ;
    rdfs:subClassOf trees:Certification ;
    rdfs:label "TREES Gold"@en ;
    rdfs:label "TREES ระดับทอง"@th ;
    rdfs:comment "TREES Gold certification level. Requires minimum 60 points and maximum 79 points. Demonstrates strong commitment to environmental sustainability and green building practices."@en ;
    rdfs:comment "ระดับการรับรอง TREES Gold ต้องการคะแนนขั้นต่ำ 60 คะแนนและสูงสุด 79 คะแนน แสดงถึงความมุ่งมั่นที่แข็งแกร่งต่อความยั่งยืนด้านสิ่งแวดล้อมและแนวปฏิบัติอาคารเขียว"@th .

trees:Platinum
    rdf:type rdfs:Class ;
    rdfs:subClassOf trees:Certification ;
    rdfs:label "TREES Platinum"@en ;
    rdfs:label "TREES ระดับแพลทินัม"@th ;
    rdfs:comment "TREES Platinum certification level. Requires minimum 80 points (maximum 100 points). Represents the highest level of green building achievement with exceptional environmental performance and innovation."@en ;
    rdfs:comment "ระดับการรับรอง TREES Platinum ต้องการคะแนนขั้นต่ำ 80 คะแนน (สูงสุด 100 คะแนน) แสดงถึงระดับสูงสุดของความสำเร็จด้านอาคารเขียว ด้วยประสิทธิภาพสิ่งแวดล้อมและนวัตกรรมที่ยอดเยี่ยม"@th .


#
# Project and Building Type Classes
#

trees:Project
    rdf:type rdfs:Class ;
    rdfs:label "TREES Project"@en ;
    rdfs:label "โครงการ TREES"@th ;
    rdfs:comment "Represents a building project seeking TREES certification. Contains project metadata, building specifications, material quantities, and assessment results across all rating categories."@en ;
    rdfs:comment "แสดงถึงโครงการอาคารที่ขอการรับรอง TREES ประกอบด้วยข้อมูลโครงการ ข้อกำหนดอาคาร ปริมาณวัสดุ และผลการประเมินทุกหมวดการประเมิน"@th .

trees:BuildingType
    rdf:type rdfs:Class ;
    rdfs:label "Building Type"@en ;
    rdfs:label "ประเภทอาคาร"@th ;
    rdfs:comment "Classification of building types for TREES certification. Different building types may have varying baseline assumptions and optimization strategies."@en ;
    rdfs:comment "การจำแนกประเภทอาคารสำหรับการรับรอง TREES ประเภทอาคารที่แตกต่างกันอาจมีสมมติฐานเกณฑ์ฐานและกลยุทธ์การเพิ่มประสิทธิภาพที่แตกต่างกัน"@th .

trees:Office
    rdf:type trees:BuildingType ;
    rdfs:label "Office Building"@en ;
    rdfs:label "อาคารสำนักงาน"@th ;
    rdfs:comment "Office buildings including corporate headquarters, business centers, and commercial office spaces."@en ;
    rdfs:comment "อาคารสำนักงาน ได้แก่ สำนักงานใหญ่ ศูนย์ธุรกิจ และพื้นที่สำนักงานเชิงพาณิชย์"@th .

trees:Residential
    rdf:type trees:BuildingType ;
    rdfs:label "Residential"@en ;
    rdfs:label "ที่อยู่อาศัย"@th ;
    rdfs:comment "Residential buildings including condominiums, apartments, and housing developments."@en ;
    rdfs:comment "อาคารที่อยู่อาศัย ได้แก่ คอนโดมิเนียม อพาร์ทเมนต์ และโครงการที่อยู่อาศัย"@th .

trees:Retail
    rdf:type trees:BuildingType ;
    rdfs:label "Retail"@en ;
    rdfs:label "ร้านค้า"@th ;
    rdfs:comment "Retail buildings including shopping malls, department stores, and commercial retail spaces."@en ;
    rdfs:comment "อาคารค้าปลีก ได้แก่ ห้างสรรพสินค้า ศูนย์การค้า และพื้นที่ค้าปลีกเชิงพาณิชย์"@th .

trees:Hotel
    rdf:type trees:BuildingType ;
    rdfs:label "Hotel"@en ;
    rdfs:label "โรงแรม"@th ;
    rdfs:comment "Hotels, resorts, and hospitality facilities."@en ;
    rdfs:comment "โรงแรม รีสอร์ท และสิ่งอำนวยความสะดวกด้านการบริการ"@th .


#
# Rating Categories
#

trees:RatingCategory
    rdf:type rdfs:Class ;
    rdfs:label "Rating Category"@en ;
    rdfs:label "หมวดการประเมิน"@th ;
    rdfs:comment "Base class for TREES rating categories. Each category contains multiple criteria that contribute points toward certification."@en ;
    rdfs:comment "คลาสหลักสำหรับหมวดการประเมิน TREES แต่ละหมวดประกอบด้วยเกณฑ์หลายรายการที่มีส่วนช่วยคะแนนสู่การรับรอง"@th .

trees:MaterialsAndResources
    rdf:type trees:RatingCategory ;
    rdfs:label "Materials and Resources (MR)"@en ;
    rdfs:label "วัสดุและทรัพยากร (MR)"@th ;
    rdfs:comment "Materials and Resources category. Focuses on sustainable material selection, recycled content, reused materials, and green-labeled products. Maximum 15 points available."@en ;
    rdfs:comment "หมวดวัสดุและทรัพยากร เน้นการเลือกใช้วัสดุที่ยั่งยืน เนื้อหารีไซเคิล วัสดุนำกลับมาใช้ใหม่ และผลิตภัณฑ์ที่มีฉลากสิ่งแวดล้อม คะแนนเต็ม 15 คะแนน"@th ;
    trees:maxPoints "15"^^xsd:integer .

trees:EnergyAndAtmosphere
    rdf:type trees:RatingCategory ;
    rdfs:label "Energy and Atmosphere (EA)"@en ;
    rdfs:label "พลังงานและบรรยากาศ (EA)"@th ;
    rdfs:comment "Energy and Atmosphere category. Focuses on energy efficiency, renewable energy, and emissions reduction. Maximum 32 points available."@en ;
    rdfs:comment "หมวดพลังงานและบรรยากาศ เน้นประสิทธิภาพพลังงาน พลังงานหมุนเวียน และการลดการปล่อยก๊าซเรือนกระจก คะแนนเต็ม 32 คะแนน"@th ;
    trees:maxPoints "32"^^xsd:integer .

trees:WaterEfficiency
    rdf:type trees:RatingCategory ;
    rdfs:label "Water Efficiency (WE)"@en ;
    rdfs:label "ประสิทธิภาพการใช้น้ำ (WE)"@th ;
    rdfs:comment "Water Efficiency category. Focuses on water conservation, efficient fixtures, and water reuse. Maximum 12 points available."@en ;
    rdfs:comment "หมวดประสิทธิภาพการใช้น้ำ เน้นการอนุรักษ์น้ำ อุปกรณ์ประหยัดน้ำ และการนำน้ำกลับมาใช้ใหม่ คะแนนเต็ม 12 คะแนน"@th ;
    trees:maxPoints "12"^^xsd:integer .

trees:IndoorEnvironmentalQuality
    rdf:type trees:RatingCategory ;
    rdfs:label "Indoor Environmental Quality (IEQ)"@en ;
    rdfs:label "คุณภาพสิ่งแวดล้อมภายในอาคาร (IEQ)"@th ;
    rdfs:comment "Indoor Environmental Quality category. Focuses on air quality, thermal comfort, lighting, and acoustics. Maximum 16 points available."@en ;
    rdfs:comment "หมวดคุณภาพสิ่งแวดล้อมภายในอาคาร เน้นคุณภาพอากาศ ความสะดวกสบายด้านความร้อน แสงสว่าง และเสียง คะแนนเต็ม 16 คะแนน"@th ;
    trees:maxPoints "16"^^xsd:integer .


#
# Materials & Resources Criteria Classes
#

trees:MaterialsCriterion
    rdf:type rdfs:Class ;
    rdfs:subClassOf trees:RatingCategory ;
    rdfs:label "Materials Criterion"@en ;
    rdfs:label "เกณฑ์วัสดุ"@th ;
    rdfs:comment "Base class for Materials & Resources (MR) criteria. Each criterion specifies requirements and point allocation for sustainable material practices."@en ;
    rdfs:comment "คลาสหลักสำหรับเกณฑ์หมวดวัสดุและทรัพยากร (MR) แต่ละเกณฑ์ระบุข้อกำหนดและการจัดสรรคะแนนสำหรับแนวปฏิบัติวัสดุที่ยั่งยืน"@th .

trees:GreenLabeledMaterialsCriterion
    rdf:type rdfs:Class ;
    rdfs:subClassOf trees:MaterialsCriterion ;
    rdfs:label "MR 1: Green/Carbon Labeled Materials"@en ;
    rdfs:label "MR 1: วัสดุที่มีฉลากสิ่งแวดล้อม/ฉลากคาร์บอน"@th ;
    rdfs:comment "MR1 criterion: Green/Carbon Labeled Materials. Rewards use of materials with recognized environmental certifications (TGO Carbon Label, Thai Green Label, FSC, Cradle to Cradle, etc.). Requires minimum 30% of total material cost. Maximum 10 points available."@en ;
    rdfs:comment "เกณฑ์ MR1: วัสดุที่มีฉลากสิ่งแวดล้อม/ฉลากคาร์บอน ให้คะแนนการใช้วัสดุที่มีการรับรองด้านสิ่งแวดล้อมที่เป็นที่ยอมรับ (ฉลากคาร์บอน TGO, ฉลากสิ่งแวดล้อมไทย, FSC, Cradle to Cradle เป็นต้น) ต้องการอย่างน้อย 30% ของต้นทุนวัสดุทั้งหมด คะแนนเต็ม 10 คะแนน"@th ;
    trees:maxPoints "10"^^xsd:integer .

trees:ReusedMaterialsCriterion
    rdf:type rdfs:Class ;
    rdfs:subClassOf trees:MaterialsCriterion ;
    rdfs:label "MR 3: Reused Materials"@en ;
    rdfs:label "MR 3: วัสดุนำกลับมาใช้ใหม่"@th ;
    rdfs:comment "MR3 criterion: Reused Materials. Rewards use of salvaged, reclaimed, or refurbished materials and components. Points awarded based on percentage of total material cost: 5% = 3 points, 10% = 5 points (maximum). Encourages waste reduction and circular economy practices."@en ;
    rdfs:comment "เกณฑ์ MR3: วัสดุนำกลับมาใช้ใหม่ ให้คะแนนการใช้วัสดุและส่วนประกอบที่กู้คืน รื้อถอนมา หรือปรับปรุงใหม่ ให้คะแนนตามเปอร์เซ็นต์ของต้นทุนวัสดุทั้งหมด: 5% = 3 คะแนน, 10% = 5 คะแนน (สูงสุด) ส่งเสริมการลดของเสียและแนวปฏิบัติเศรษฐกิจหมุนเวียน"@th ;
    trees:maxPoints "5"^^xsd:integer .


#
# Well-Known Instances - Criterion Rules
#

trees:MR1Rule
    rdf:type trees:GreenLabeledMaterialsCriterion , owl:NamedIndividual ;
    rdfs:label "MR1: Green/Carbon Labeled Materials Rule"@en ;
    rdfs:label "กฎ MR1: วัสดุที่มีฉลากสิ่งแวดล้อม/ฉลากคาร์บอน"@th ;
    trees:criterionCode "MR1" ;
    trees:requiredPercentage "0.30"^^xsd:decimal ;
    trees:maxPoints "10"^^xsd:integer ;
    trees:version "1.1" ;
    rdfs:comment """TREES NC 1.1 MR1: Green/Carbon Labeled Materials

    Requirement: Minimum 30% of total material cost must have recognized green labels or carbon labels

    Recognized Labels:
    - TGO Carbon Label (ฉลากคาร์บอนฟุตพริ้นท์ของผลิตภัณฑ์ องค์การบริหารจัดการก๊าซเรือนกระจก)
    - Thai Green Label (ฉลากเขียว / Green Label Thailand)
    - FSC (Forest Stewardship Council)
    - Cradle to Cradle Certified
    - ISO Type I Environmental Labels
    - EPD (Environmental Product Declaration)
    - Other TGBI-approved labels

    Point Calculation:
    - Calculate: Green Material Cost / Total Material Cost
    - If >= 30% (0.30): Award 10 points
    - If < 30%: Award 0 points (no partial credit for MR1)

    Cost Basis:
    - Based on actual material purchase price (excluding labor)
    - Must be documented with invoices and label certificates
    - Material cost excludes MEP equipment, furniture, and finishes

    Integration with TGO:
    - Link materials via trees:hasGreenLabel property
    - Verify label status through TGO database
    - Track label type via trees:greenLabelType property

    Example:
    Total material cost: 10,000,000 THB
    Green-labeled materials: 3,500,000 THB
    Percentage: 35% >= 30% ✓ Award 10 points
    """@en .

trees:MR3Rule
    rdf:type trees:ReusedMaterialsCriterion , owl:NamedIndividual ;
    rdfs:label "MR3: Reused Materials Rule"@en ;
    rdfs:label "กฎ MR3: วัสดุนำกลับมาใช้ใหม่"@th ;
    trees:criterionCode "MR3" ;
    trees:minPercentageFor3Points "0.05"^^xsd:decimal ;
    trees:minPercentageFor5Points "0.10"^^xsd:decimal ;
    trees:maxPoints "5"^^xsd:integer ;
    trees:version "1.1" ;
    rdfs:comment """TREES NC 1.1 MR3: Reused Materials

    Requirement: Use salvaged, reclaimed, or refurbished materials and components

    Qualifying Materials:
    - Salvaged materials from demolition sites
    - Reclaimed timber, bricks, steel, etc.
    - Refurbished doors, windows, fixtures
    - Architectural elements from historic buildings
    - Factory seconds or surplus materials

    Point Calculation:
    - Calculate: Reused Material Cost / Total Material Cost
    - If >= 10% (0.10): Award 5 points (maximum)
    - If >= 5% (0.05) and < 10%: Award 3 points
    - If < 5%: Award 0 points

    Cost Basis:
    - Based on current replacement value of reused materials
    - Must be documented with procurement records
    - Material cost excludes MEP equipment and finishes

    Documentation Required:
    - Source of reused materials
    - Quantity and type of materials
    - Cost calculation methodology
    - Quality certification (structural integrity, safety)

    Integration with TGO:
    - Link materials via trees:isReused property
    - Track reuse type via trees:reuseCategory property
    - Document source via trees:materialSource property

    Example 1:
    Total material cost: 10,000,000 THB
    Reused materials: 600,000 THB
    Percentage: 6% >= 5% and < 10% ✓ Award 3 points

    Example 2:
    Total material cost: 10,000,000 THB
    Reused materials: 1,200,000 THB
    Percentage: 12% >= 10% ✓ Award 5 points (maximum)
    """@en .


#
# Material Assessment Classes
#

trees:MaterialsAssessment
    rdf:type rdfs:Class ;
    rdfs:label "Materials Assessment"@en ;
    rdfs:label "การประเมินวัสดุ"@th ;
    rdfs:comment "Complete materials assessment for a TREES project. Includes material inventory, green label verification, reused material tracking, cost calculations, and MR category point totals."@en ;
    rdfs:comment "การประเมินวัสดุที่สมบูรณ์สำหรับโครงการ TREES รวมถึงบัญชีวัสดุ การตรวจสอบฉลากสิ่งแวดล้อม การติดตามวัสดุนำกลับมาใช้ใหม่ การคำนวณต้นทุน และยอดคะแนนหมวด MR"@th .

trees:MaterialUsage
    rdf:type rdfs:Class ;
    rdfs:label "Material Usage"@en ;
    rdfs:label "การใช้วัสดุ"@th ;
    rdfs:comment "Represents the usage of a specific construction material in a TREES project. Links material quantities, costs, and properties to TGO material database for certification assessment."@en ;
    rdfs:comment "แสดงถึงการใช้วัสดุก่อสร้างเฉพาะในโครงการ TREES เชื่อมโยงปริมาณวัสดุ ต้นทุน และคุณสมบัติไปยังฐานข้อมูลวัสดุ TGO สำหรับการประเมินการรับรอง"@th .

trees:GreenLabeledMaterial
    rdf:type rdfs:Class ;
    rdfs:subClassOf trees:MaterialUsage ;
    rdfs:label "Green Labeled Material"@en ;
    rdfs:label "วัสดุที่มีฉลากสิ่งแวดล้อม"@th ;
    rdfs:comment "Material with recognized green or carbon label. Contributes to MR1 criterion points. Must have valid certification from approved labeling schemes."@en ;
    rdfs:comment "วัสดุที่มีฉลากสิ่งแวดล้อมหรือฉลากคาร์บอนที่เป็นที่ยอมรับ มีส่วนช่วยคะแนนเกณฑ์ MR1 ต้องมีการรับรองที่ถูกต้องจากโครงการฉลากที่ได้รับอนุมัติ"@th .

trees:ReusedMaterial
    rdf:type rdfs:Class ;
    rdfs:subClassOf trees:MaterialUsage ;
    rdfs:label "Reused Material"@en ;
    rdfs:label "วัสดุนำกลับมาใช้ใหม่"@th ;
    rdfs:comment "Salvaged, reclaimed, or refurbished material. Contributes to MR3 criterion points. Must be documented with source and quality certification."@en ;
    rdfs:comment "วัสดุกู้คืน รื้อถอนมา หรือปรับปรุงใหม่ มีส่วนช่วยคะแนนเกณฑ์ MR3 ต้องมีเอกสารแหล่งที่มาและการรับรองคุณภาพ"@th .


#
# Class Restrictions and Cardinality Constraints
#

# Project must have required properties
trees:Project
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty trees:projectID ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty trees:projectName ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty trees:hasBuildingType ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger
    ] .

# MaterialsAssessment must have required properties
trees:MaterialsAssessment
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty trees:totalMaterialCost ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty trees:assessmentDate ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty trees:totalPoints ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger
    ] .

# MaterialUsage must have quantity and cost
trees:MaterialUsage
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty trees:materialQuantity ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty trees:materialCost ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty trees:usesConstructionMaterial ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger
    ] .


#
# Object Properties - Project Relationships
#

trees:hasCertification
    rdf:type owl:ObjectProperty ;
    rdfs:label "has certification"@en ;
    rdfs:label "มีการรับรอง"@th ;
    rdfs:domain trees:Project ;
    rdfs:range trees:Certification ;
    rdfs:comment "Links a project to its achieved or target TREES certification level (Certified, Gold, or Platinum)."@en .

trees:hasBuildingType
    rdf:type owl:ObjectProperty ;
    rdfs:label "has building type"@en ;
    rdfs:label "มีประเภทอาคาร"@th ;
    rdfs:domain trees:Project ;
    rdfs:range trees:BuildingType ;
    rdfs:comment "Specifies the building type classification for the project (Office, Residential, Retail, Hotel)."@en .

trees:hasMaterialsAssessment
    rdf:type owl:ObjectProperty ;
    rdfs:label "has materials assessment"@en ;
    rdfs:label "มีการประเมินวัสดุ"@th ;
    rdfs:domain trees:Project ;
    rdfs:range trees:MaterialsAssessment ;
    rdfs:comment "Links a project to its complete materials assessment including MR1 and MR3 criteria evaluation."@en ;
    owl:inverseOf trees:isAssessmentOf .

trees:hasMaterialUsage
    rdf:type owl:ObjectProperty ;
    rdfs:label "has material usage"@en ;
    rdfs:label "มีการใช้วัสดุ"@th ;
    rdfs:domain trees:Project ;
    rdfs:range trees:MaterialUsage ;
    rdfs:comment "Links a project to instances of material usage including green-labeled and reused materials."@en .

trees:usesConstructionMaterial
    rdf:type owl:ObjectProperty ;
    rdfs:label "uses construction material"@en ;
    rdfs:label "ใช้วัสดุก่อสร้าง"@th ;
    rdfs:domain trees:MaterialUsage ;
    rdfs:range tgo:ConstructionMaterial ;
    rdfs:comment "Links material usage to the specific TGO construction material. Enables retrieval of emission factors and material properties from TGO ontology."@en ;
    owl:inverseOf trees:isUsedInMaterialUsage .


#
# Inverse Object Properties
#

trees:isAssessmentOf
    rdf:type owl:ObjectProperty ;
    rdfs:label "is assessment of"@en ;
    rdfs:label "เป็นการประเมินของ"@th ;
    rdfs:domain trees:MaterialsAssessment ;
    rdfs:range trees:Project ;
    owl:inverseOf trees:hasMaterialsAssessment ;
    rdfs:comment "Inverse of hasMaterialsAssessment. Links a materials assessment back to its project."@en .

trees:isUsedInMaterialUsage
    rdf:type owl:ObjectProperty ;
    rdfs:label "is used in material usage"@en ;
    rdfs:label "ถูกใช้ในการใช้วัสดุ"@th ;
    rdfs:domain tgo:ConstructionMaterial ;
    rdfs:range trees:MaterialUsage ;
    owl:inverseOf trees:usesConstructionMaterial ;
    rdfs:comment "Inverse of usesConstructionMaterial. Links a TGO material to all material usage instances where it is used."@en .


#
# Datatype Properties - Project Metadata
#

trees:projectName
    rdf:type owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "project name"@en ;
    rdfs:label "ชื่อโครงการ"@th ;
    rdfs:domain trees:Project ;
    rdfs:range xsd:string ;
    rdfs:comment "Official name of the building project seeking TREES certification."@en .

trees:projectID
    rdf:type owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "project ID"@en ;
    rdfs:label "รหัสโครงการ"@th ;
    rdfs:domain trees:Project ;
    rdfs:range xsd:string ;
    rdfs:comment "Unique identifier for the TREES project. May be internal system ID or TREES certification reference number."@en .

trees:projectLocation
    rdf:type owl:DatatypeProperty ;
    rdfs:label "project location"@en ;
    rdfs:label "ที่ตั้งโครงการ"@th ;
    rdfs:domain trees:Project ;
    rdfs:range xsd:string ;
    rdfs:comment "Geographic location of the project in Thailand. Format: 'District, Province' or coordinates."@en .

trees:grossFloorArea
    rdf:type owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "gross floor area"@en ;
    rdfs:label "พื้นที่รวม"@th ;
    rdfs:domain trees:Project ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Total gross floor area of the building in square meters (m²). Used for normalization and intensity calculations."@en .

trees:certificationDate
    rdf:type owl:DatatypeProperty ;
    rdfs:label "certification date"@en ;
    rdfs:label "วันที่รับรอง"@th ;
    rdfs:domain trees:Project ;
    rdfs:range xsd:date ;
    rdfs:comment "Date when TREES certification was awarded by TGBI. Part of audit trail and temporal tracking."@en .


#
# Datatype Properties - Scoring and Points
#

trees:totalPoints
    rdf:type owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "total points"@en ;
    rdfs:label "คะแนนรวม"@th ;
    rdfs:domain trees:MaterialsAssessment ;
    rdfs:range xsd:integer ;
    rdfs:comment "Total points achieved in Materials & Resources category. Sum of MR1, MR3, and other MR criteria points."@en .

trees:mr1Points
    rdf:type owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "MR1 points"@en ;
    rdfs:label "คะแนน MR1"@th ;
    rdfs:domain trees:MaterialsAssessment ;
    rdfs:range xsd:integer ;
    rdfs:comment "Points achieved for MR1 (Green/Carbon Labeled Materials). Range: 0-10 points."@en .

trees:mr3Points
    rdf:type owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "MR3 points"@en ;
    rdfs:label "คะแนน MR3"@th ;
    rdfs:domain trees:MaterialsAssessment ;
    rdfs:range xsd:integer ;
    rdfs:comment "Points achieved for MR3 (Reused Materials). Range: 0-5 points."@en .

trees:requiredScore
    rdf:type owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "required score"@en ;
    rdfs:label "คะแนนที่ต้องการ"@th ;
    rdfs:domain trees:Certification ;
    rdfs:range xsd:integer ;
    rdfs:comment "Minimum total points required for certification level. Certified: 50, Gold: 60, Platinum: 80."@en .

trees:maxPoints
    rdf:type owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "maximum points"@en ;
    rdfs:label "คะแนนสูงสุด"@th ;
    rdfs:range xsd:integer ;
    rdfs:comment "Maximum points available for a criterion or category."@en .


#
# Datatype Properties - Material Cost and Percentage
#

trees:totalMaterialCost
    rdf:type owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "total material cost"@en ;
    rdfs:label "ต้นทุนวัสดุรวม"@th ;
    rdfs:domain trees:MaterialsAssessment ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Total cost of all materials in the project (THB). Excludes labor, MEP equipment, furniture, and finishes. Used as denominator for percentage calculations."@en .

trees:greenLabeledMaterialCost
    rdf:type owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "green labeled material cost"@en ;
    rdfs:label "ต้นทุนวัสดุที่มีฉลากสิ่งแวดล้อม"@th ;
    rdfs:domain trees:MaterialsAssessment ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Total cost of green-labeled materials (THB). Used for MR1 percentage calculation."@en .

trees:reusedMaterialCost
    rdf:type owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "reused material cost"@en ;
    rdfs:label "ต้นทุนวัสดุนำกลับมาใช้ใหม่"@th ;
    rdfs:domain trees:MaterialsAssessment ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Total cost of reused materials (THB). Based on current replacement value. Used for MR3 percentage calculation."@en .

trees:greenLabeledPercentage
    rdf:type owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "green labeled percentage"@en ;
    rdfs:label "เปอร์เซ็นต์วัสดุที่มีฉลากสิ่งแวดล้อม"@th ;
    rdfs:domain trees:MaterialsAssessment ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Percentage of green-labeled materials by cost. Calculated as: (greenLabeledMaterialCost / totalMaterialCost) × 100. Must be >= 30% for MR1 points."@en .

trees:reusedPercentage
    rdf:type owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "reused percentage"@en ;
    rdfs:label "เปอร์เซ็นต์วัสดุนำกลับมาใช้ใหม่"@th ;
    rdfs:domain trees:MaterialsAssessment ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Percentage of reused materials by cost. Calculated as: (reusedMaterialCost / totalMaterialCost) × 100. >= 5% = 3 points, >= 10% = 5 points."@en .

trees:materialCost
    rdf:type owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "material cost"@en ;
    rdfs:label "ต้นทุนวัสดุ"@th ;
    rdfs:domain trees:MaterialUsage ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Cost of this specific material in Thai Baht (THB). Excludes labor and installation costs."@en .

trees:materialQuantity
    rdf:type owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "material quantity"@en ;
    rdfs:label "ปริมาณวัสดุ"@th ;
    rdfs:domain trees:MaterialUsage ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Quantity of material used. Must match the functional unit in tgo:hasUnit (e.g., kg, m³, m², pieces)."@en .


#
# Datatype Properties - Green Label and Reuse Tracking
#

trees:hasGreenLabel
    rdf:type owl:DatatypeProperty ;
    rdfs:label "has green label"@en ;
    rdfs:label "มีฉลากสิ่งแวดล้อม"@th ;
    rdfs:domain trees:MaterialUsage ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Boolean flag indicating if material has a recognized green or carbon label. True = contributes to MR1."@en .

trees:greenLabelType
    rdf:type owl:DatatypeProperty ;
    rdfs:label "green label type"@en ;
    rdfs:label "ประเภทฉลากสิ่งแวดล้อม"@th ;
    rdfs:domain trees:MaterialUsage ;
    rdfs:range xsd:string ;
    rdfs:comment "Type of green label. Values: 'TGO_Carbon_Label', 'Thai_Green_Label', 'FSC', 'Cradle_to_Cradle', 'EPD', 'ISO_Type_I', etc."@en .

trees:greenLabelCertificateNumber
    rdf:type owl:DatatypeProperty ;
    rdfs:label "green label certificate number"@en ;
    rdfs:label "หมายเลขใบรับรองฉลากสิ่งแวดล้อม"@th ;
    rdfs:domain trees:MaterialUsage ;
    rdfs:range xsd:string ;
    rdfs:comment "Certificate or registration number for the green label. Used for verification and audit purposes."@en .

trees:isReused
    rdf:type owl:DatatypeProperty ;
    rdfs:label "is reused"@en ;
    rdfs:label "เป็นวัสดุนำกลับมาใช้ใหม่"@th ;
    rdfs:domain trees:MaterialUsage ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Boolean flag indicating if material is salvaged, reclaimed, or refurbished. True = contributes to MR3."@en .

trees:reuseCategory
    rdf:type owl:DatatypeProperty ;
    rdfs:label "reuse category"@en ;
    rdfs:label "หมวดการนำกลับมาใช้ใหม่"@th ;
    rdfs:domain trees:MaterialUsage ;
    rdfs:range xsd:string ;
    rdfs:comment "Category of reuse. Values: 'Salvaged', 'Reclaimed', 'Refurbished', 'Factory_Seconds', 'Surplus'."@en .

trees:materialSource
    rdf:type owl:DatatypeProperty ;
    rdfs:label "material source"@en ;
    rdfs:label "แหล่งที่มาของวัสดุ"@th ;
    rdfs:domain trees:MaterialUsage ;
    rdfs:range xsd:string ;
    rdfs:comment "Source or origin of material. For reused materials, document the original building or demolition site."@en .


#
# Datatype Properties - Criterion Configuration
#

trees:criterionCode
    rdf:type owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "criterion code"@en ;
    rdfs:label "รหัสเกณฑ์"@th ;
    rdfs:domain trees:MaterialsCriterion ;
    rdfs:range xsd:string ;
    rdfs:comment "TREES criterion code. Examples: 'MR1', 'MR3', 'EA1', 'WE1', etc."@en .

trees:requiredPercentage
    rdf:type owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "required percentage"@en ;
    rdfs:label "เปอร์เซ็นต์ที่ต้องการ"@th ;
    rdfs:domain trees:MaterialsCriterion ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Required percentage threshold for criterion. For MR1: 0.30 (30%). Stored as decimal (e.g., 0.30 = 30%)."@en .

trees:minPercentageFor3Points
    rdf:type owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "minimum percentage for 3 points"@en ;
    rdfs:label "เปอร์เซ็นต์ขั้นต่ำสำหรับ 3 คะแนน"@th ;
    rdfs:domain trees:ReusedMaterialsCriterion ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Minimum percentage threshold for partial points in MR3. Value: 0.05 (5%)."@en .

trees:minPercentageFor5Points
    rdf:type owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "minimum percentage for 5 points"@en ;
    rdfs:label "เปอร์เซ็นต์ขั้นต่ำสำหรับ 5 คะแนน"@th ;
    rdfs:domain trees:ReusedMaterialsCriterion ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Minimum percentage threshold for maximum points in MR3. Value: 0.10 (10%)."@en .

trees:version
    rdf:type owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "version"@en ;
    rdfs:label "เวอร์ชัน"@th ;
    rdfs:range xsd:string ;
    rdfs:comment "TREES certification version. Current: '1.1'. Critical for tracking requirement changes over time."@en .


#
# Datatype Properties - Assessment Status
#

trees:assessmentDate
    rdf:type owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "assessment date"@en ;
    rdfs:label "วันที่ประเมิน"@th ;
    rdfs:domain trees:MaterialsAssessment ;
    rdfs:range xsd:date ;
    rdfs:comment "Date when the materials assessment was performed. Critical for version control and data staleness detection."@en .

trees:complianceStatus
    rdf:type owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "compliance status"@en ;
    rdfs:label "สถานะการปฏิบัติตาม"@th ;
    rdfs:domain trees:MaterialsAssessment ;
    rdfs:range xsd:string ;
    rdfs:comment "Compliance status of materials assessment. Values: 'PASS' (meets requirements), 'FAIL' (does not meet), 'PENDING' (under review), 'NOT_ASSESSED'."@en .

trees:assessmentNotes
    rdf:type owl:DatatypeProperty ;
    rdfs:label "assessment notes"@en ;
    rdfs:label "หมายเหตุการประเมิน"@th ;
    rdfs:domain trees:MaterialsAssessment ;
    rdfs:range xsd:string ;
    rdfs:comment "Additional notes, assumptions, or limitations of the assessment. Include documentation requirements, verification status, etc."@en .


#
# Audit Trail and Provenance
#

trees:assessedBy
    rdf:type owl:ObjectProperty ;
    rdfs:label "assessed by"@en ;
    rdfs:label "ประเมินโดย"@th ;
    rdfs:domain trees:MaterialsAssessment ;
    rdfs:range foaf:Agent ;
    rdfs:comment "URI reference to the person or organization that performed the materials assessment. Part of audit trail."@en .

trees:verifiedBy
    rdf:type owl:ObjectProperty ;
    rdfs:label "verified by"@en ;
    rdfs:label "ตรวจสอบโดย"@th ;
    rdfs:domain trees:MaterialsAssessment ;
    rdfs:range foaf:Agent ;
    rdfs:comment "URI reference to the TGBI assessor who verified the assessment. Required for official TREES certification."@en .

trees:verificationDate
    rdf:type owl:DatatypeProperty ;
    rdfs:label "verification date"@en ;
    rdfs:label "วันที่ตรวจสอบ"@th ;
    rdfs:domain trees:MaterialsAssessment ;
    rdfs:range xsd:date ;
    rdfs:comment "Date when the assessment was verified by a TGBI assessor. Part of certification timeline tracking."@en .


#
# SPARQL Query Examples (for documentation)
#

# Query 1: Calculate MR1 compliance and points
# PREFIX trees: <http://tgbi.or.th/trees/ontology#>
# SELECT ?project ?greenPercentage ?mr1Points ?status
# WHERE {
#   ?project trees:hasMaterialsAssessment ?assessment .
#   ?assessment trees:greenLabeledPercentage ?greenPercentage ;
#               trees:mr1Points ?mr1Points ;
#               trees:complianceStatus ?status .
#   FILTER (?greenPercentage >= 30.0)
# }

# Query 2: Calculate MR3 points based on reused percentage
# PREFIX trees: <http://tgbi.or.th/trees/ontology#>
# SELECT ?project ?reusedPercentage
#        (IF(?reusedPercentage >= 10.0, 5,
#            IF(?reusedPercentage >= 5.0, 3, 0)) AS ?mr3Points)
# WHERE {
#   ?project trees:hasMaterialsAssessment ?assessment .
#   ?assessment trees:reusedPercentage ?reusedPercentage .
# }

# Query 3: List all green-labeled materials in project
# PREFIX trees: <http://tgbi.or.th/trees/ontology#>
# PREFIX tgo: <http://tgo.or.th/ontology#>
# SELECT ?material ?label ?labelType ?cost
# WHERE {
#   ?usage rdf:type trees:GreenLabeledMaterial ;
#          trees:usesConstructionMaterial ?tgoMaterial ;
#          trees:greenLabelType ?labelType ;
#          trees:materialCost ?cost .
#   ?tgoMaterial rdfs:label ?label .
#   FILTER (lang(?label) = "en")
# }

# Query 4: Calculate total Materials & Resources points
# PREFIX trees: <http://tgbi.or.th/trees/ontology#>
# SELECT ?project ?mr1Points ?mr3Points (?mr1Points + ?mr3Points AS ?totalMRPoints)
# WHERE {
#   ?project trees:hasMaterialsAssessment ?assessment .
#   ?assessment trees:mr1Points ?mr1Points ;
#               trees:mr3Points ?mr3Points .
# }

# Query 5: Verify TREES Gold eligibility (60+ points total)
# PREFIX trees: <http://tgbi.or.th/trees/ontology#>
# SELECT ?project ?totalPoints
#        (IF(?totalPoints >= 80, "Platinum",
#            IF(?totalPoints >= 60, "Gold",
#               IF(?totalPoints >= 50, "Certified", "Not Certified"))) AS ?level)
# WHERE {
#   ?project trees:hasMaterialsAssessment ?assessment .
#   ?assessment trees:totalPoints ?totalPoints .
# }

# Query 6: Find materials with both green labels and reuse
# PREFIX trees: <http://tgbi.or.th/trees/ontology#>
# PREFIX tgo: <http://tgo.or.th/ontology#>
# SELECT ?material ?label ?greenLabel ?isReused
# WHERE {
#   ?usage trees:usesConstructionMaterial ?tgoMaterial ;
#          trees:hasGreenLabel ?greenLabel ;
#          trees:isReused ?isReused .
#   ?tgoMaterial rdfs:label ?label .
#   FILTER (?greenLabel = true && ?isReused = true)
#   FILTER (lang(?label) = "en")
# }

# Query 7: Calculate cost breakdown for MR criteria
# PREFIX trees: <http://tgbi.or.th/trees/ontology#>
# SELECT ?project ?totalCost ?greenCost ?reusedCost
#        (?greenCost * 100.0 / ?totalCost AS ?greenPct)
#        (?reusedCost * 100.0 / ?totalCost AS ?reusedPct)
# WHERE {
#   ?project trees:hasMaterialsAssessment ?assessment .
#   ?assessment trees:totalMaterialCost ?totalCost ;
#               trees:greenLabeledMaterialCost ?greenCost ;
#               trees:reusedMaterialCost ?reusedCost .
# }


#
# End of TREES NC 1.1 Ontology
#
