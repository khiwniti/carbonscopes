#
# TGO (Thailand Greenhouse Gas Management Organization) Ontology
#
# Purpose: RDF/RDFS schema for Thai construction material emission factors
# Namespace: http://tgo.or.th/ontology#
# Version: 1.0.0
# Created: 2026-03-22
# License: To be confirmed with TGO (info@tgo.or.th)
#
# Data Sources:
#   - TGO Carbon Footprint of Products (CFP): https://thaicarbonlabel.tgo.or.th
#   - TGO Carbon Footprint of Organization (CFO): https://thaicarbonlabel.tgo.or.th
#   - TGO GHG Reduction Portal (T-VER): https://ghgreduction.tgo.or.th
#   - TIIS National LCI Database: https://www.nstda-tiis.or.th/en/lci-database/
#
# Design Decisions:
#   1. Uses RDFS (not OWL) for compatibility with GraphDB RDFS inference ruleset
#   2. xsd:decimal for emission factors (NOT float) - consultant-grade precision required
#   3. Bilingual labels (Thai + English) with NFC Unicode normalization
#   4. Provenance tracking via effectiveDate and sourceDocument properties
#   5. Class hierarchy enables fallback matching for similar materials
#   6. Named graph versioning strategy for temporal data management
#
# Coverage:
#   - Target: 500+ construction materials
#   - Base TGO data: ~50-100 emission factors
#   - Expansion via category breakdown + BOQ variations + regional factors
#
# GraphDB Repository: carbonbim-thailand (RDFS inference enabled)
#

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix tgo: <http://tgo.or.th/ontology#> .

#
# Ontology Metadata
#

<http://tgo.or.th/ontology>
    rdf:type owl:Ontology ;
    dcterms:title "TGO Construction Materials Emission Factor Ontology"@en ;
    dcterms:title "ออนโทโลยีค่าการปล่อยก๊าซเรือนกระจกของวัสดุก่อสร้าง TGO"@th ;
    dcterms:description "RDF schema for Thai construction material carbon emission factors from Thailand Greenhouse Gas Management Organization (TGO)"@en ;
    dcterms:description "โครงร่างข้อมูล RDF สำหรับค่าการปล่อยคาร์บอนของวัสดุก่อสร้างไทยจากองค์การบริหารจัดการก๊าซเรือนกระจก (อบก.)"@th ;
    dcterms:creator "carbonscope BIM Platform" ;
    dcterms:created "2026-03-22"^^xsd:date ;
    dcterms:modified "2026-03-22"^^xsd:date ;
    owl:versionInfo "1.0.0" ;
    rdfs:comment "This ontology uses RDFS semantics for compatibility with GraphDB's RDFS inference ruleset. Precision is critical: xsd:decimal is used for all numeric emission factors to ensure ≤2% error tolerance for consultant-grade carbon assessments."@en ;
    rdfs:seeAlso <https://thaicarbonlabel.tgo.or.th> ;
    rdfs:seeAlso <https://ghgreduction.tgo.or.th> ;
    rdfs:seeAlso <https://www.nstda-tiis.or.th/en/lci-database/> .


#
# Class Hierarchy - Construction Materials
#
# Design rationale:
#   - Base class tgo:ConstructionMaterial enables generic material queries
#   - Subclasses enable category-specific queries and fallback matching
#   - RDFS inference will automatically infer tgo:ConstructionMaterial type
#     for all instances of subclasses
#

tgo:ConstructionMaterial
    rdf:type rdfs:Class ;
    rdfs:label "Construction Material"@en ;
    rdfs:label "วัสดุก่อสร้าง"@th ;
    rdfs:comment "Base class for all construction materials with associated carbon emission factors. Instances include concrete, steel, aluminum, glass, wood, insulation, and other building materials used in Thai construction projects."@en ;
    rdfs:comment "คลาสหลักสำหรับวัสดุก่อสร้างทั้งหมดที่มีค่าการปล่อยก๊าซเรือนกระจก รวมถึงคอนกรีต เหล็ก อลูมิเนียม กระจก ไม้ ฉนวน และวัสดุก่อสร้างอื่นๆ ที่ใช้ในโครงการก่อสร้างในประเทศไทย"@th .

tgo:Concrete
    rdf:type rdfs:Class ;
    rdfs:subClassOf tgo:ConstructionMaterial ;
    rdfs:label "Concrete"@en ;
    rdfs:label "คอนกรีต"@th ;
    rdfs:comment "Concrete and concrete products including ready-mix concrete, precast concrete, concrete blocks, and specialty concrete mixes. Emission factors vary by concrete grade (C15, C20, C25, C30, etc.) and admixtures."@en ;
    rdfs:comment "คอนกรีตและผลิตภัณฑ์คอนกรีต ได้แก่ คอนกรีตผสมเสร็จ คอนกรีตสำเร็จรูป บล็อกคอนกรีต และคอนกรีตพิเศษต่างๆ ค่าการปล่อยฯ แตกต่างกันตามเกรดคอนกรีต (C15, C20, C25, C30 เป็นต้น) และสารเติมแต่ง"@th .

tgo:Steel
    rdf:type rdfs:Class ;
    rdfs:subClassOf tgo:ConstructionMaterial ;
    rdfs:label "Steel"@en ;
    rdfs:label "เหล็ก"@th ;
    rdfs:comment "Steel products including structural steel, reinforcement bars (rebar), steel beams, steel sheets, and steel sections. Includes both carbon steel and alloy steel. One of the highest emission intensity materials in construction."@en ;
    rdfs:comment "ผลิตภัณฑ์เหล็ก ได้แก่ เหล็กโครงสร้าง เหล็กเสริมคอนกรีต (เหล็กเส้น) คานเหล็ก แผ่นเหล็ก และท่อนเหล็กรูปพรรณต่างๆ รวมถึงเหล็กกล้าคาร์บอนและเหล็กผสม เป็นวัสดุที่มีค่าการปล่อยฯ สูงที่สุดกลุ่มหนึ่งในการก่อสร้าง"@th .

tgo:Aluminum
    rdf:type rdfs:Class ;
    rdfs:subClassOf tgo:ConstructionMaterial ;
    rdfs:label "Aluminum"@en ;
    rdfs:label "อลูมิเนียม"@th ;
    rdfs:comment "Aluminum products including window frames, door frames, curtain walls, cladding panels, and aluminum sections. Emission factors differ significantly between primary aluminum (from bauxite ore) and recycled aluminum."@en ;
    rdfs:comment "ผลิตภัณฑ์อลูมิเนียม ได้แก่ กรอบหน้าต่าง กรอบประตู ผนังม่านกระจก แผ่นหุ้มผนัง และโปรไฟล์อลูมิเนียม ค่าการปล่อยฯ แตกต่างกันมากระหว่างอลูมิเนียมปฐมภูมิ (จากแร่บอกไซต์) และอลูมิเนียมรีไซเคิล"@th .

tgo:Glass
    rdf:type rdfs:Class ;
    rdfs:subClassOf tgo:ConstructionMaterial ;
    rdfs:label "Glass"@en ;
    rdfs:label "กระจก"@th ;
    rdfs:comment "Glass products including float glass, tempered glass, laminated glass, low-E glass, and insulated glass units. Emission factors vary by glass type, coating, and thickness."@en ;
    rdfs:comment "ผลิตภัณฑ์กระจก ได้แก่ กระจกใส กระจกเทมเปอร์ กระจกลามิเนต กระจกเคลือบ Low-E และกระจกสองชั้น ค่าการปล่อยฯ แตกต่างกันตามชนิดกระจก การเคลือบ และความหนา"@th .

tgo:Wood
    rdf:type rdfs:Class ;
    rdfs:subClassOf tgo:ConstructionMaterial ;
    rdfs:label "Wood"@en ;
    rdfs:label "ไม้"@th ;
    rdfs:comment "Wood and wood products including timber, plywood, particle board, MDF, OSB, and engineered wood. Generally has lower emission factors compared to steel and concrete, especially for sustainably sourced wood with carbon sequestration benefits."@en ;
    rdfs:comment "ไม้และผลิตภัณฑ์ไม้ ได้แก่ ไม้แปรรูป ไม้อัด แผ่นไม้อนุภาค MDF, OSB และไม้วิศวกรรม โดยทั่วไปมีค่าการปล่อยฯ ต่ำกว่าเหล็กและคอนกรีต โดยเฉพาะไม้ที่มาจากแหล่งที่ยั่งยืนซึ่งมีประโยชน์ในการดักจับคาร์บอน"@th .

tgo:Insulation
    rdf:type rdfs:Class ;
    rdfs:subClassOf tgo:ConstructionMaterial ;
    rdfs:label "Insulation"@en ;
    rdfs:label "ฉนวน"@th ;
    rdfs:comment "Thermal insulation materials including fiberglass, mineral wool, expanded polystyrene (EPS), extruded polystyrene (XPS), polyurethane foam, and cellulose insulation. Critical for building energy efficiency but emission factors vary widely by material type."@en ;
    rdfs:comment "วัสดุฉนวนกันความร้อน ได้แก่ ใยแก้ว แร่ใยหิน โฟมพอลิสไตรีนชนิดขยาย (EPS) โฟมพอลิสไตรีนชนิดอัดรีด (XPS) โฟมโพลียูรีเทน และฉนวนเซลลูโลส มีความสำคัญต่อประสิทธิภาพพลังงานของอาคาร แต่ค่าการปล่อยฯ แตกต่างกันมากตามประเภทวัสดุ"@th .

tgo:Ceramic
    rdf:type rdfs:Class ;
    rdfs:subClassOf tgo:ConstructionMaterial ;
    rdfs:label "Ceramic"@en ;
    rdfs:label "เซรามิก"@th ;
    rdfs:comment "Ceramic products including ceramic tiles, porcelain tiles, terracotta, and ceramic sanitary ware. Emission factors depend on firing temperature and raw materials."@en ;
    rdfs:comment "ผลิตภัณฑ์เซรามิก ได้แก่ กระเบื้องเซรามิก กระเบื้องพอร์ซเลน เทอราคอตตา และสุขภัณฑ์เซรามิก ค่าการปล่อยฯ ขึ้นอยู่กับอุณหภูมิการเผาและวัตถุดิบ"@th .

tgo:Cement
    rdf:type rdfs:Class ;
    rdfs:subClassOf tgo:ConstructionMaterial ;
    rdfs:label "Cement"@en ;
    rdfs:label "ปูนซีเมนต์"@th ;
    rdfs:comment "Cement products including Portland cement (Type I-V), blended cement, and specialty cements. Cement production is one of the largest sources of CO2 emissions in the construction industry due to calcination process."@en ;
    rdfs:comment "ผลิตภัณฑ์ปูนซีเมนต์ ได้แก่ ปูนซีเมนต์ปอร์ตแลนด์ (ชนิด I-V) ปูนซีเมนต์ผสม และปูนซีเมนต์พิเศษ การผลิตปูนซีเมนต์เป็นแหล่งปล่อย CO2 ที่ใหญ่ที่สุดแหล่งหนึ่งในอุตสาหกรรมก่อสร้างเนื่องจากกระบวนการแคลไซเนชัน"@th .

tgo:Masonry
    rdf:type rdfs:Class ;
    rdfs:subClassOf tgo:ConstructionMaterial ;
    rdfs:label "Masonry"@en ;
    rdfs:label "วัสดุก่อผนัง"@th ;
    rdfs:comment "Masonry materials including clay bricks, concrete blocks, autoclaved aerated concrete (AAC), and mortar. Common in Thai residential and low-rise construction."@en ;
    rdfs:comment "วัสดุก่อผนัง ได้แก่ อิฐดินเผา บล็อกคอนกรีต คอนกรีตมวลเบา (AAC) และปูนก่อ ใช้กันอย่างแพร่หลายในที่อยู่อาศัยและอาคารเตี้ยในประเทศไทย"@th .

tgo:Gypsum
    rdf:type rdfs:Class ;
    rdfs:subClassOf tgo:ConstructionMaterial ;
    rdfs:label "Gypsum"@en ;
    rdfs:label "ยิปซั่ม"@th ;
    rdfs:comment "Gypsum products including gypsum board, gypsum plaster, and fiber-reinforced gypsum panels. Commonly used for interior walls and ceilings."@en ;
    rdfs:comment "ผลิตภัณฑ์ยิปซั่ม ได้แก่ แผ่นยิปซั่มบอร์ด ปูนปลาสเตอร์ยิปซั่ม และแผ่นยิปซั่มเสริมเส้นใย ใช้กันทั่วไปสำหรับผนังและเพลาดาน"@th .

tgo:Paint
    rdf:type rdfs:Class ;
    rdfs:subClassOf tgo:ConstructionMaterial ;
    rdfs:label "Paint and Coatings"@en ;
    rdfs:label "สี"@th ;
    rdfs:comment "Paints, coatings, and surface treatments including water-based paint, oil-based paint, varnish, and protective coatings. Emission factors include VOC emissions during application and curing."@en ;
    rdfs:comment "สี สารเคลือบผิว และการปรับผิว ได้แก่ สีน้ำ สีน้ำมัน วานิช และสารเคลือบป้องกัน ค่าการปล่อยฯ รวมถึงการปล่อย VOC ระหว่างการทาและการแห้งตัว"@th .


#
# Object Properties - Relationships between materials and other entities
#

tgo:hasMaterialCategory
    rdf:type rdf:Property ;
    rdfs:label "has material category"@en ;
    rdfs:label "มีหมวดหมู่วัสดุ"@th ;
    rdfs:domain tgo:ConstructionMaterial ;
    rdfs:range rdfs:Literal ;
    rdfs:comment "Categorizes the material by its primary function or composition. Examples: 'Structural', 'Finishing', 'Insulation', 'Waterproofing'. Enables filtering and aggregation by category."@en .

tgo:relatedToStandard
    rdf:type rdf:Property ;
    rdfs:label "related to standard"@en ;
    rdfs:label "เกี่ยวข้องกับมาตรฐาน"@th ;
    rdfs:domain tgo:ConstructionMaterial ;
    rdfs:comment "Links the material to relevant Thai Industrial Standards (TIS), ISO standards, or ASTM standards. Enables compliance checking and material specification validation."@en .

tgo:applicableToLifecycleStage
    rdf:type rdf:Property ;
    rdfs:label "applicable to lifecycle stage"@en ;
    rdfs:label "เหมาะสำหรับขั้นตอนวงจรชีวิต"@th ;
    rdfs:domain tgo:ConstructionMaterial ;
    rdfs:comment "Specifies which lifecycle stage(s) the emission factor applies to: 'A1-A3' (product stage), 'A4' (transport), 'A5' (construction), 'B1-B7' (use stage), 'C1-C4' (end of life), 'D' (beyond building lifecycle). Follows EN 15804 standard."@en .


#
# Datatype Properties - Emission factors and metadata
#

tgo:hasEmissionFactor
    rdf:type rdf:Property ;
    rdfs:label "has emission factor"@en ;
    rdfs:label "มีค่าการปล่อยก๊าซเรือนกระจก"@th ;
    rdfs:domain tgo:ConstructionMaterial ;
    rdfs:range xsd:decimal ;
    rdfs:comment "The carbon emission factor in kgCO2e per functional unit. CRITICAL: Must use xsd:decimal (not xsd:float) to maintain precision for consultant-grade assessments. Target accuracy: ≤2% error tolerance."@en ;
    rdfs:comment "ค่าการปล่อยก๊าซเรือนกระจกในหน่วย kgCO2e ต่อหน่วยการใช้งาน สำคัญ: ต้องใช้ xsd:decimal (ไม่ใช่ xsd:float) เพื่อรักษาความแม่นยำสำหรับการประเมินในระดับที่ปรึกษา เป้าหมายความแม่นยำ: ≤2% ความคลาดเคลื่อน"@th .

tgo:hasUnit
    rdf:type rdf:Property ;
    rdfs:label "has unit"@en ;
    rdfs:label "มีหน่วย"@th ;
    rdfs:domain tgo:ConstructionMaterial ;
    rdfs:range rdfs:Literal ;
    rdfs:comment "Functional unit for the emission factor. Common units: 'kg' (kilogram), 'm³' (cubic meter), 'm²' (square meter), 'ton' (metric ton), 'piece' (per item). Must match Thai construction BOQ (Bill of Quantities) conventions."@en ;
    rdfs:comment "หน่วยการใช้งานสำหรับค่าการปล่อยฯ หน่วยที่ใช้กันทั่วไป: 'kg' (กิโลกรัม), 'm³' (ลูกบาศก์เมตร), 'm²' (ตารางเมตร), 'ton' (ตัน), 'piece' (ต่อชิ้น) ต้องสอดคล้องกับหน่วยที่ใช้ในรายการประมาณการ (BOQ) ของไทย"@th .

tgo:category
    rdf:type rdf:Property ;
    rdfs:label "category"@en ;
    rdfs:label "หมวดหมู่"@th ;
    rdfs:domain tgo:ConstructionMaterial ;
    rdfs:range rdfs:Literal ;
    rdfs:comment "High-level category for grouping materials. Values: 'Concrete', 'Steel', 'Aluminum', 'Glass', 'Wood', 'Insulation', 'Ceramic', 'Cement', 'Masonry', 'Gypsum', 'Paint', etc. Used for dashboard visualizations and category-based analysis."@en .

tgo:effectiveDate
    rdf:type rdf:Property ;
    rdfs:label "effective date"@en ;
    rdfs:label "วันที่มีผลใช้"@th ;
    rdfs:domain tgo:ConstructionMaterial ;
    rdfs:range xsd:date ;
    rdfs:comment "The date when this emission factor became effective. Critical for temporal versioning and staleness detection. TGO typically updates emission factors annually. System should warn if data is >6 months old."@en ;
    rdfs:comment "วันที่ค่าการปล่อยฯ นี้มีผลใช้ มีความสำคัญสำหรับการควบคุมเวอร์ชันตามเวลาและการตรวจสอบความเก่าของข้อมูล TGO ปกติจะอัปเดตค่าการปล่อยฯ ทุกปี ระบบควรเตือนหากข้อมูลเก่ากว่า 6 เดือน"@th .

tgo:sourceDocument
    rdf:type rdf:Property ;
    rdfs:label "source document"@en ;
    rdfs:label "เอกสารอ้างอิง"@th ;
    rdfs:domain tgo:ConstructionMaterial ;
    rdfs:comment "URI or reference to the source document where this emission factor was published. Examples: TGO CFP database, TIIS LCI database, peer-reviewed journal. Enables provenance tracking and audit trails."@en .

tgo:dataQuality
    rdf:type rdf:Property ;
    rdfs:label "data quality"@en ;
    rdfs:label "คุณภาพข้อมูล"@th ;
    rdfs:domain tgo:ConstructionMaterial ;
    rdfs:range rdfs:Literal ;
    rdfs:comment "Data quality indicator following ecoinvent or ILCD conventions: 'Verified' (peer-reviewed), 'Estimated' (calculated from similar materials), 'Generic' (industry average), 'Specific' (product-specific EPD). Helps users assess reliability."@en .

tgo:uncertainty
    rdf:type rdf:Property ;
    rdfs:label "uncertainty"@en ;
    rdfs:label "ความไม่แน่นอน"@th ;
    rdfs:domain tgo:ConstructionMaterial ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Uncertainty range as percentage (e.g., '0.15' for ±15%). Based on Monte Carlo analysis or expert judgment. Critical for sensitivity analysis and risk assessment in large projects."@en .

tgo:geographicScope
    rdf:type rdf:Property ;
    rdfs:label "geographic scope"@en ;
    rdfs:label "ขอบเขตภูมิศาสตร์"@th ;
    rdfs:domain tgo:ConstructionMaterial ;
    rdfs:range rdfs:Literal ;
    rdfs:comment "Geographic applicability of the emission factor. Values: 'Thailand' (national average), 'Bangkok' (regional), 'ASEAN' (regional adaptation), 'Global' (international database). Thai-specific factors are preferred for accuracy."@en .

tgo:technologyLevel
    rdf:type rdf:Property ;
    rdfs:label "technology level"@en ;
    rdfs:label "ระดับเทคโนโลยี"@th ;
    rdfs:domain tgo:ConstructionMaterial ;
    rdfs:range rdfs:Literal ;
    rdfs:comment "Production technology level: 'Best Available Technology (BAT)', 'Current Technology', 'Mix of Technologies'. Reflects the production methods included in the emission factor calculation."@en .

tgo:thaiLabel
    rdf:type rdf:Property ;
    rdfs:subPropertyOf rdfs:label ;
    rdfs:label "Thai label"@en ;
    rdfs:label "ชื่อภาษาไทย"@th ;
    rdfs:domain tgo:ConstructionMaterial ;
    rdfs:range rdf:langString ;
    rdfs:comment "Material name in Thai language with @th language tag. Must use NFC (Canonical Decomposition followed by Canonical Composition) Unicode normalization to ensure consistent text matching. Critical for Thai BOQ integration."@en .

tgo:englishLabel
    rdf:type rdf:Property ;
    rdfs:subPropertyOf rdfs:label ;
    rdfs:label "English label"@en ;
    rdfs:label "ชื่อภาษาอังกฤษ"@th ;
    rdfs:domain tgo:ConstructionMaterial ;
    rdfs:range rdf:langString ;
    rdfs:comment "Material name in English with @en language tag. Follows international construction terminology. Used for API responses and international user interfaces."@en .

tgo:alternativeName
    rdf:type rdf:Property ;
    rdfs:label "alternative name"@en ;
    rdfs:label "ชื่อทางเลือก"@th ;
    rdfs:domain tgo:ConstructionMaterial ;
    rdfs:range rdfs:Literal ;
    rdfs:comment "Alternative names, trade names, or regional variations. Examples: 'Rebar' (alternative for 'Reinforcement Bar'), 'Ready-mix' (alternative for 'Ready-mixed Concrete'). Improves fuzzy matching accuracy."@en .

tgo:materialSpecification
    rdf:type rdf:Property ;
    rdfs:label "material specification"@en ;
    rdfs:label "คุณสมบัติวัสดุ"@th ;
    rdfs:domain tgo:ConstructionMaterial ;
    rdfs:range rdfs:Literal ;
    rdfs:comment "Technical specification details: concrete grade (C15, C20, C30), steel grade (SD40, SS400), thickness, density, etc. Enables precise material matching for BOQ line items."@en .

tgo:notes
    rdf:type rdf:Property ;
    rdfs:label "notes"@en ;
    rdfs:label "หมายเหตุ"@th ;
    rdfs:domain tgo:ConstructionMaterial ;
    rdfs:range rdfs:Literal ;
    rdfs:comment "Additional notes, assumptions, or limitations. Examples: 'Includes transport to Bangkok', 'Excludes end-of-life stage', 'Based on 2025 Thai electricity grid mix'. Critical for transparent reporting."@en .


#
# Named Graph Versioning Strategy
#
# Design:
#   - Each TGO data release is loaded into a separate named graph
#   - Named graph URI format: http://tgo.or.th/versions/YYYY-MM
#   - Default graph queries across all versions (latest takes precedence)
#   - Version-specific queries use GRAPH clause
#   - Staleness detection via SPARQL queries on tgo:effectiveDate
#
# Example Usage:
#   GRAPH <http://tgo.or.th/versions/2026-03> { ... }
#
# Staleness Query:
#   SELECT ?material ?date
#   WHERE {
#     ?material tgo:effectiveDate ?date .
#     FILTER (?date < "2025-09-22"^^xsd:date)  # 6 months ago
#   }
#

tgo:DataVersion
    rdf:type rdfs:Class ;
    rdfs:label "Data Version"@en ;
    rdfs:label "เวอร์ชันข้อมูล"@th ;
    rdfs:comment "Represents a versioned snapshot of TGO emission factor data. Each version corresponds to a named graph with URI format http://tgo.or.th/versions/YYYY-MM."@en .

tgo:versionDate
    rdf:type rdf:Property ;
    rdfs:label "version date"@en ;
    rdfs:label "วันที่เวอร์ชัน"@th ;
    rdfs:domain tgo:DataVersion ;
    rdfs:range xsd:date ;
    rdfs:comment "The publication date of this data version. TGO typically releases annual updates. Used for version comparison and migration planning."@en .

tgo:versionNotes
    rdf:type rdf:Property ;
    rdfs:label "version notes"@en ;
    rdfs:label "หมายเหตุเวอร์ชัน"@th ;
    rdfs:domain tgo:DataVersion ;
    rdfs:range rdfs:Literal ;
    rdfs:comment "Release notes describing what changed in this version: new materials added, emission factors updated, methodology changes, etc."@en .

tgo:previousVersion
    rdf:type rdf:Property ;
    rdfs:label "previous version"@en ;
    rdfs:label "เวอร์ชันก่อนหน้า"@th ;
    rdfs:domain tgo:DataVersion ;
    rdfs:range tgo:DataVersion ;
    rdfs:comment "Links to the previous version for version history tracking. Enables automated version comparison and migration scripts."@en .


#
# Validation and Quality Control
#

tgo:ValidationStatus
    rdf:type rdfs:Class ;
    rdfs:label "Validation Status"@en ;
    rdfs:label "สถานะการตรวจสอบ"@th ;
    rdfs:comment "Represents validation status of emission factor data: Validated, Pending, Rejected. Used for quality control workflow."@en .

tgo:validationStatus
    rdf:type rdf:Property ;
    rdfs:label "validation status"@en ;
    rdfs:label "สถานะการตรวจสอบ"@th ;
    rdfs:domain tgo:ConstructionMaterial ;
    rdfs:range tgo:ValidationStatus ;
    rdfs:comment "Current validation status of the emission factor data. All TGO data should be marked 'Validated'. User-contributed or estimated data should be marked 'Pending' until verified."@en .

tgo:validatedBy
    rdf:type rdf:Property ;
    rdfs:label "validated by"@en ;
    rdfs:label "ตรวจสอบโดย"@th ;
    rdfs:domain tgo:ConstructionMaterial ;
    rdfs:comment "URI reference to the person or organization that validated this data. For TGO data, this would be TGO organization URI."@en .

tgo:validationDate
    rdf:type rdf:Property ;
    rdfs:label "validation date"@en ;
    rdfs:label "วันที่ตรวจสอบ"@th ;
    rdfs:domain tgo:ConstructionMaterial ;
    rdfs:range xsd:date ;
    rdfs:comment "Date when the emission factor was validated. Part of the audit trail for quality assurance."@en .


#
# Example Instance (for reference - actual data loaded separately)
#
# Uncomment to include example:
#
# <http://tgo.or.th/materials/concrete-c30-rmc>
#     rdf:type tgo:Concrete ;
#     rdfs:label "Ready-mixed Concrete C30"@en ;
#     rdfs:label "คอนกรีตผสมเสร็จ C30"@th ;
#     tgo:hasEmissionFactor "445.6"^^xsd:decimal ;
#     tgo:hasUnit "kgCO2e/m³" ;
#     tgo:category "Concrete" ;
#     tgo:effectiveDate "2026-01-01"^^xsd:date ;
#     tgo:sourceDocument <https://thaicarbonlabel.tgo.or.th/admin/uploadfiles/emission/...> ;
#     tgo:dataQuality "Verified" ;
#     tgo:uncertainty "0.10"^^xsd:decimal ;
#     tgo:geographicScope "Thailand" ;
#     tgo:materialSpecification "Grade C30, 28-day strength 30 MPa" ;
#     tgo:notes "Includes cement, aggregate, water, admixtures. Excludes transport and placement." .


#
# SPARQL Query Examples (for documentation)
#
# 1. Find all concrete materials:
#    SELECT ?material ?label ?emissionFactor
#    WHERE {
#      ?material a tgo:Concrete ;
#                rdfs:label ?label ;
#                tgo:hasEmissionFactor ?emissionFactor .
#      FILTER (lang(?label) = "en")
#    }
#
# 2. Find materials by category:
#    SELECT ?material ?label ?category
#    WHERE {
#      ?material tgo:category ?category ;
#                rdfs:label ?label .
#      FILTER (?category = "Steel")
#    }
#
# 3. Find stale emission factors (>6 months old):
#    SELECT ?material ?label ?effectiveDate
#    WHERE {
#      ?material tgo:effectiveDate ?effectiveDate ;
#                rdfs:label ?label .
#      FILTER (?effectiveDate < "2025-09-22"^^xsd:date)
#    }
#
# 4. Bilingual label retrieval:
#    SELECT ?materialEN ?materialTH
#    WHERE {
#      ?material rdfs:label ?materialEN ;
#                rdfs:label ?materialTH .
#      FILTER (lang(?materialEN) = "en")
#      FILTER (lang(?materialTH) = "th")
#    }
#
# 5. Materials with uncertainty range:
#    SELECT ?material ?label ?emissionFactor ?uncertainty
#    WHERE {
#      ?material rdfs:label ?label ;
#                tgo:hasEmissionFactor ?emissionFactor ;
#                tgo:uncertainty ?uncertainty .
#      FILTER (?uncertainty > 0.20)  # >20% uncertainty
#    }
#

#
# End of TGO Ontology
#
