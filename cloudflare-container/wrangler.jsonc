{
  "name": "carbonscope-backend",
  "main": "src/index.ts",
  "compatibility_date": "2025-04-01",
  "containers": [
    {
      "name": "backend",
      "image": "ghcr.io/khiwniti/carbonscopes-backend:latest",
      "port": 8080,
      "memory": "2Gi",
      "health_check": {
        "path": "/healthz",
        "interval_seconds": 30
      }
    }
  ]
}
