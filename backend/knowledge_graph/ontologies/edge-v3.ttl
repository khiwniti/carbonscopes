@prefix edge: <http://edgebuildings.com/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

edge:EDGE a owl:Class ;
    edge:requiredReduction "0.20"^^xsd:decimal ;
    edge:version "3.1"^^xsd:string .

edge:embodiedCarbonSavingsRule a owl:Class ;
    edge:threshold "0.20"^^xsd:decimal ;
    edge:comparisonMethod "percentage_reduction_vs_baseline" .
