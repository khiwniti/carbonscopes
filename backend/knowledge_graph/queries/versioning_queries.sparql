#
# TGO Named Graph Versioning SPARQL Query Templates
#
# Purpose: Reusable SPARQL queries for version management, staleness detection,
#          and version comparison of TGO emission factor data.
#
# Version URI Format: http://tgo.or.th/versions/YYYY-MM
#
# Usage: Replace placeholders with actual values:
#   - {THRESHOLD_DATE} - Date in YYYY-MM-DD format for staleness checks
#   - {VERSION_URI} - Full version URI (e.g., http://tgo.or.th/versions/2024-12)
#   - {OLD_VERSION_URI} - Old version for comparison
#   - {NEW_VERSION_URI} - New version for comparison
#

#
# 1. FIND STALE EMISSION FACTORS (>6 months old)
#
# Description: Identifies materials with emission factors older than a threshold date.
# Use Case: Monthly data quality checks, staleness warnings in UI
# Parameters: {THRESHOLD_DATE} in format YYYY-MM-DD
#
PREFIX tgo: <http://tgo.or.th/ontology#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

SELECT DISTINCT ?material ?label ?effectiveDate ?category ?emissionFactor ?ageInMonths
WHERE {
    ?material tgo:effectiveDate ?effectiveDate ;
             rdfs:label ?label .
    OPTIONAL { ?material tgo:category ?category }
    OPTIONAL { ?material tgo:hasEmissionFactor ?emissionFactor }

    # Calculate approximate age in months (rough estimate)
    BIND(xsd:integer((NOW() - ?effectiveDate) / 30) as ?ageInMonths)

    FILTER (?effectiveDate < "{THRESHOLD_DATE}"^^xsd:date)
    FILTER (lang(?label) = "en" || lang(?label) = "")
}
ORDER BY ?effectiveDate ?label


#
# 2. LIST ALL AVAILABLE VERSIONS
#
# Description: Retrieves all TGO data versions with metadata
# Use Case: Version selection dropdowns, version history display
#
PREFIX tgo: <http://tgo.or.th/ontology#>

SELECT DISTINCT ?versionUri ?versionDate ?notes ?previousVersion
WHERE {
    GRAPH ?versionUri {
        ?version a tgo:DataVersion .
        OPTIONAL { ?version tgo:versionDate ?versionDate }
        OPTIONAL { ?version tgo:versionNotes ?notes }
        OPTIONAL { ?version tgo:previousVersion ?previousVersion }
    }
    FILTER (STRSTARTS(STR(?versionUri), "http://tgo.or.th/versions/"))
}
ORDER BY DESC(?versionDate)


#
# 3. COUNT MATERIALS IN A SPECIFIC VERSION
#
# Description: Counts total materials in a version
# Use Case: Version metadata, data quality checks
# Parameters: {VERSION_URI}
#
PREFIX tgo: <http://tgo.or.th/ontology#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT (COUNT(DISTINCT ?material) as ?materialCount)
WHERE {
    GRAPH <{VERSION_URI}> {
        ?material a ?type .
        ?type rdfs:subClassOf* tgo:ConstructionMaterial .
    }
}


#
# 4. COUNT MATERIALS BY CATEGORY IN A VERSION
#
# Description: Breakdown of materials by category in a specific version
# Use Case: Data quality dashboards, category coverage analysis
# Parameters: {VERSION_URI}
#
PREFIX tgo: <http://tgo.or.th/ontology#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?category (COUNT(DISTINCT ?material) as ?count)
WHERE {
    GRAPH <{VERSION_URI}> {
        ?material a ?type ;
                 tgo:category ?category .
        ?type rdfs:subClassOf* tgo:ConstructionMaterial .
    }
}
GROUP BY ?category
ORDER BY DESC(?count)


#
# 5. FIND ADDED MATERIALS (in new version, not in old)
#
# Description: Identifies materials that were added in the new version
# Use Case: Version comparison, release notes generation
# Parameters: {OLD_VERSION_URI}, {NEW_VERSION_URI}
#
PREFIX tgo: <http://tgo.or.th/ontology#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT DISTINCT ?material ?label ?emissionFactor ?category ?unit
WHERE {
    GRAPH <{NEW_VERSION_URI}> {
        ?material a ?type ;
                 rdfs:label ?label .
        ?type rdfs:subClassOf* tgo:ConstructionMaterial .
        OPTIONAL { ?material tgo:hasEmissionFactor ?emissionFactor }
        OPTIONAL { ?material tgo:category ?category }
        OPTIONAL { ?material tgo:hasUnit ?unit }
        FILTER (lang(?label) = "en" || lang(?label) = "")
    }
    FILTER NOT EXISTS {
        GRAPH <{OLD_VERSION_URI}> {
            ?material a ?anyType .
        }
    }
}
ORDER BY ?category ?label


#
# 6. FIND REMOVED MATERIALS (in old version, not in new)
#
# Description: Identifies materials that were removed in the new version
# Use Case: Version comparison, deprecation warnings
# Parameters: {OLD_VERSION_URI}, {NEW_VERSION_URI}
#
PREFIX tgo: <http://tgo.or.th/ontology#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT DISTINCT ?material ?label ?emissionFactor ?category ?unit
WHERE {
    GRAPH <{OLD_VERSION_URI}> {
        ?material a ?type ;
                 rdfs:label ?label .
        ?type rdfs:subClassOf* tgo:ConstructionMaterial .
        OPTIONAL { ?material tgo:hasEmissionFactor ?emissionFactor }
        OPTIONAL { ?material tgo:category ?category }
        OPTIONAL { ?material tgo:hasUnit ?unit }
        FILTER (lang(?label) = "en" || lang(?label) = "")
    }
    FILTER NOT EXISTS {
        GRAPH <{NEW_VERSION_URI}> {
            ?material a ?anyType .
        }
    }
}
ORDER BY ?category ?label


#
# 7. FIND UPDATED MATERIALS (emission factor changed)
#
# Description: Identifies materials where emission factor was modified
# Use Case: Version comparison, impact analysis for existing projects
# Parameters: {OLD_VERSION_URI}, {NEW_VERSION_URI}
#
PREFIX tgo: <http://tgo.or.th/ontology#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT DISTINCT ?material ?label ?oldEmissionFactor ?newEmissionFactor ?category
       (((?newEmissionFactor - ?oldEmissionFactor) / ?oldEmissionFactor) * 100 as ?changePercent)
WHERE {
    GRAPH <{OLD_VERSION_URI}> {
        ?material a ?type ;
                 rdfs:label ?label ;
                 tgo:hasEmissionFactor ?oldEmissionFactor .
        ?type rdfs:subClassOf* tgo:ConstructionMaterial .
        OPTIONAL { ?material tgo:category ?category }
        FILTER (lang(?label) = "en" || lang(?label) = "")
    }
    GRAPH <{NEW_VERSION_URI}> {
        ?material tgo:hasEmissionFactor ?newEmissionFactor .
    }
    FILTER (?oldEmissionFactor != ?newEmissionFactor)
}
ORDER BY DESC(ABS(?changePercent))


#
# 8. FIND UNCHANGED MATERIALS (same emission factor)
#
# Description: Identifies materials with no changes between versions
# Use Case: Version comparison completeness check
# Parameters: {OLD_VERSION_URI}, {NEW_VERSION_URI}
#
PREFIX tgo: <http://tgo.or.th/ontology#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT DISTINCT ?material ?label ?emissionFactor ?category
WHERE {
    GRAPH <{OLD_VERSION_URI}> {
        ?material a ?type ;
                 rdfs:label ?label ;
                 tgo:hasEmissionFactor ?emissionFactor .
        ?type rdfs:subClassOf* tgo:ConstructionMaterial .
        OPTIONAL { ?material tgo:category ?category }
        FILTER (lang(?label) = "en" || lang(?label) = "")
    }
    GRAPH <{NEW_VERSION_URI}> {
        ?material tgo:hasEmissionFactor ?emissionFactor .
    }
}
ORDER BY ?category ?label


#
# 9. GET LATEST VERSION FOR EACH MATERIAL
#
# Description: Retrieves the most recent emission factor for each material across all versions
# Use Case: Default queries without version specification, "latest data" view
#
PREFIX tgo: <http://tgo.or.th/ontology#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?material ?label ?emissionFactor ?category ?effectiveDate ?versionUri
WHERE {
    {
        SELECT ?material (MAX(?date) as ?latestDate)
        WHERE {
            GRAPH ?g {
                ?material tgo:effectiveDate ?date .
            }
            FILTER (STRSTARTS(STR(?g), "http://tgo.or.th/versions/"))
        }
        GROUP BY ?material
    }
    GRAPH ?versionUri {
        ?material tgo:effectiveDate ?latestDate ;
                 rdfs:label ?label ;
                 tgo:hasEmissionFactor ?emissionFactor .
        OPTIONAL { ?material tgo:category ?category }
        FILTER (lang(?label) = "en" || lang(?label) = "")
    }
    BIND(?latestDate as ?effectiveDate)
}
ORDER BY ?category ?label


#
# 10. FIND MATERIALS WITH HIGH UNCERTAINTY (>20%)
#
# Description: Identifies materials with high data uncertainty
# Use Case: Data quality improvement prioritization
# Parameters: {VERSION_URI} (optional, remove GRAPH clause to query all versions)
#
PREFIX tgo: <http://tgo.or.th/ontology#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT DISTINCT ?material ?label ?emissionFactor ?uncertainty ?category
WHERE {
    GRAPH <{VERSION_URI}> {
        ?material a ?type ;
                 rdfs:label ?label ;
                 tgo:hasEmissionFactor ?emissionFactor ;
                 tgo:uncertainty ?uncertainty .
        ?type rdfs:subClassOf* tgo:ConstructionMaterial .
        OPTIONAL { ?material tgo:category ?category }
        FILTER (?uncertainty > 0.20)  # >20% uncertainty
        FILTER (lang(?label) = "en" || lang(?label) = "")
    }
}
ORDER BY DESC(?uncertainty)


#
# 11. VERSION COMPARISON SUMMARY
#
# Description: High-level summary of changes between two versions
# Use Case: Release notes, migration decision support
# Parameters: {OLD_VERSION_URI}, {NEW_VERSION_URI}
#
PREFIX tgo: <http://tgo.or.th/ontology#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT
    (COUNT(DISTINCT ?oldMaterial) as ?oldVersionCount)
    (COUNT(DISTINCT ?newMaterial) as ?newVersionCount)
WHERE {
    {
        GRAPH <{OLD_VERSION_URI}> {
            ?oldMaterial a ?type .
            ?type rdfs:subClassOf* tgo:ConstructionMaterial .
        }
    }
    UNION
    {
        GRAPH <{NEW_VERSION_URI}> {
            ?newMaterial a ?type .
            ?type rdfs:subClassOf* tgo:ConstructionMaterial .
        }
    }
}


#
# 12. FIND MATERIALS BY DATA QUALITY
#
# Description: Filter materials by data quality indicator
# Use Case: Data quality auditing, trusted vs. estimated data filtering
# Parameters: {VERSION_URI}, {QUALITY} (e.g., "Verified", "Estimated", "Generic")
#
PREFIX tgo: <http://tgo.or.th/ontology#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT DISTINCT ?material ?label ?emissionFactor ?dataQuality ?category
WHERE {
    GRAPH <{VERSION_URI}> {
        ?material a ?type ;
                 rdfs:label ?label ;
                 tgo:hasEmissionFactor ?emissionFactor ;
                 tgo:dataQuality ?dataQuality .
        ?type rdfs:subClassOf* tgo:ConstructionMaterial .
        OPTIONAL { ?material tgo:category ?category }
        FILTER (?dataQuality = "{QUALITY}")
        FILTER (lang(?label) = "en" || lang(?label) = "")
    }
}
ORDER BY ?category ?label


#
# 13. AUDIT TRAIL - TRACK VERSION CHANGES FOR A SPECIFIC MATERIAL
#
# Description: Shows the complete version history for a specific material
# Use Case: Material change tracking, audit compliance
# Parameters: {MATERIAL_URI}
#
PREFIX tgo: <http://tgo.or.th/ontology#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?versionUri ?effectiveDate ?emissionFactor ?sourceDocument ?dataQuality
WHERE {
    GRAPH ?versionUri {
        <{MATERIAL_URI}> tgo:effectiveDate ?effectiveDate ;
                        tgo:hasEmissionFactor ?emissionFactor .
        OPTIONAL { <{MATERIAL_URI}> tgo:sourceDocument ?sourceDocument }
        OPTIONAL { <{MATERIAL_URI}> tgo:dataQuality ?dataQuality }
    }
    FILTER (STRSTARTS(STR(?versionUri), "http://tgo.or.th/versions/"))
}
ORDER BY DESC(?effectiveDate)


#
# 14. FIND MATERIALS MISSING CRITICAL METADATA
#
# Description: Data quality check - materials without required properties
# Use Case: Data validation, pre-release quality gates
# Parameters: {VERSION_URI}
#
PREFIX tgo: <http://tgo.or.th/ontology#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT DISTINCT ?material ?label ?category
       (BOUND(?emissionFactor) as ?hasEmissionFactor)
       (BOUND(?unit) as ?hasUnit)
       (BOUND(?effectiveDate) as ?hasEffectiveDate)
       (BOUND(?sourceDocument) as ?hasSourceDocument)
WHERE {
    GRAPH <{VERSION_URI}> {
        ?material a ?type ;
                 rdfs:label ?label .
        ?type rdfs:subClassOf* tgo:ConstructionMaterial .
        OPTIONAL { ?material tgo:category ?category }
        OPTIONAL { ?material tgo:hasEmissionFactor ?emissionFactor }
        OPTIONAL { ?material tgo:hasUnit ?unit }
        OPTIONAL { ?material tgo:effectiveDate ?effectiveDate }
        OPTIONAL { ?material tgo:sourceDocument ?sourceDocument }
        FILTER (lang(?label) = "en" || lang(?label) = "")
    }
    FILTER (!BOUND(?emissionFactor) || !BOUND(?unit) || !BOUND(?effectiveDate))
}
ORDER BY ?category ?label


#
# 15. CALCULATE VERSION STATISTICS
#
# Description: Comprehensive statistics for a version
# Use Case: Data quality dashboards, version metadata
# Parameters: {VERSION_URI}
#
PREFIX tgo: <http://tgo.or.th/ontology#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT
    (COUNT(DISTINCT ?material) as ?totalMaterials)
    (COUNT(DISTINCT ?category) as ?categoryCount)
    (AVG(?emissionFactor) as ?avgEmissionFactor)
    (MIN(?emissionFactor) as ?minEmissionFactor)
    (MAX(?emissionFactor) as ?maxEmissionFactor)
    (COUNT(?material) FILTER(?hasUncertainty) as ?materialsWithUncertainty)
WHERE {
    GRAPH <{VERSION_URI}> {
        ?material a ?type .
        ?type rdfs:subClassOf* tgo:ConstructionMaterial .
        OPTIONAL { ?material tgo:category ?category }
        OPTIONAL { ?material tgo:hasEmissionFactor ?emissionFactor }
        OPTIONAL { ?material tgo:uncertainty ?uncertainty }
        BIND(BOUND(?uncertainty) as ?hasUncertainty)
    }
}


#
# End of Versioning SPARQL Query Templates
#
