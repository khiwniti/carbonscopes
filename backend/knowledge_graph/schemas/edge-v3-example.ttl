#
# EDGE V3 Example Usage
#
# This file demonstrates how to use the EDGE V3 ontology with TGO materials
# for a sample residential project in Bangkok, Thailand
#

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix edge: <http://edgebuildings.com/ontology#> .
@prefix tgo: <http://tgo.or.th/ontology#> .
@prefix ex: <http://example.com/projects#> .

#
# Example Project: Green Condominium Bangkok
#

ex:GreenCondoBKK
    rdf:type edge:Project ;
    edge:projectID "EDGE-TH-2026-001" ;
    edge:projectName "Green Condominium Bangkok"@en ;
    edge:projectName "คอนโดมิเนียมสีเขียว กรุงเทพฯ"@th ;
    edge:projectLocation "Bangkok, Thailand" ;
    edge:hasBuildingType edge:Residential ;
    edge:grossFloorArea "5000.0"^^xsd:decimal ;
    edge:numberOfFloors 8 ;
    edge:certificationLevel "EDGE_CERTIFIED" ;
    edge:hasCarbonAssessment ex:GreenCondoBKK_CarbonAssessment .

#
# Carbon Assessment
#

ex:GreenCondoBKK_CarbonAssessment
    rdf:type edge:CarbonAssessment ;
    edge:assessmentDate "2026-03-23"^^xsd:date ;
    edge:baselineEmissions "1198000.0"^^xsd:decimal ;  # 1,198 tonnes CO2e
    edge:projectEmissions "792500.0"^^xsd:decimal ;    # 792.5 tonnes CO2e
    edge:carbonSavings "405500.0"^^xsd:decimal ;       # 405.5 tonnes CO2e saved
    edge:carbonSavingsPercentage "33.8"^^xsd:decimal ; # 33.8% reduction ✓ PASS
    edge:carbonIntensity "158.5"^^xsd:decimal ;        # 158.5 kgCO2e/m²
    edge:complianceStatus "PASS" ;
    edge:assessedBy <http://example.com/consultants/carbonscope-team> ;
    edge:assessmentNotes "Assessment includes A1-A3 lifecycle stages only. Core structural materials: concrete, steel, masonry, and glass. Excludes finishes, MEP equipment, and landscaping. Full BOQ with 500+ materials would increase totals proportionally." ;
    edge:hasCarbonBaseline ex:GreenCondoBKK_Baseline .

#
# Baseline Material Usage (Conventional Construction)
#

ex:GreenCondoBKK_Baseline
    rdf:type edge:CarbonBaseline ;
    rdfs:comment "Baseline scenario using conventional Thai construction methods: Portland cement concrete, carbon steel, standard glazing." .

# Baseline: Ready-mixed Concrete C30 (conventional)
ex:BaselineConcrete
    rdf:type edge:BaselineMaterialUsage ;
    edge:usesConstructionMaterial <http://tgo.or.th/materials/concrete-c30-rmc> ;
    edge:materialQuantity "1200.0"^^xsd:decimal ;  # 1,200 m³
    edge:materialEmissions "534000.0"^^xsd:decimal ; # 1,200 × 445 kgCO2e/m³
    edge:materialPercentageOfTotal "23.7"^^xsd:decimal ;
    edge:lifecycleStage "A1-A3" ;
    rdfs:comment "Baseline uses standard Portland cement concrete with 445 kgCO2e/m³ emission factor." .

# Baseline: Steel Rebar (conventional)
ex:BaselineSteel
    rdf:type edge:BaselineMaterialUsage ;
    edge:usesConstructionMaterial <http://tgo.or.th/materials/steel-rebar-sd40> ;
    edge:materialQuantity "180000.0"^^xsd:decimal ;  # 180 tonnes
    edge:materialEmissions "540000.0"^^xsd:decimal ; # 180,000 kg × 3.0 kgCO2e/kg
    edge:materialPercentageOfTotal "24.0"^^xsd:decimal ;
    edge:lifecycleStage "A1-A3" ;
    rdfs:comment "Baseline uses virgin steel rebar with 3.0 kgCO2e/kg emission factor." .

# Baseline: Concrete Blocks (masonry)
ex:BaselineBlocks
    rdf:type edge:BaselineMaterialUsage ;
    edge:usesConstructionMaterial <http://tgo.or.th/materials/concrete-block-standard> ;
    edge:materialQuantity "25000.0"^^xsd:decimal ;   # 25,000 blocks
    edge:materialEmissions "100000.0"^^xsd:decimal ; # 25,000 × 4.0 kgCO2e/block
    edge:materialPercentageOfTotal "4.4"^^xsd:decimal ;
    edge:lifecycleStage "A1-A3" .

# Baseline: Standard Float Glass
ex:BaselineGlass
    rdf:type edge:BaselineMaterialUsage ;
    edge:usesConstructionMaterial <http://tgo.or.th/materials/glass-float-6mm> ;
    edge:materialQuantity "800.0"^^xsd:decimal ;     # 800 m²
    edge:materialEmissions "24000.0"^^xsd:decimal ;  # 800 × 30 kgCO2e/m²
    edge:materialPercentageOfTotal "1.1"^^xsd:decimal ;
    edge:lifecycleStage "A1-A3" .

#
# Project Material Usage (Low-Carbon Design)
#

# Project: Blended Cement Concrete (30% fly ash replacement)
ex:ProjectConcrete
    rdf:type edge:ProjectMaterialUsage ;
    edge:usesConstructionMaterial <http://tgo.or.th/materials/concrete-c30-blended-30pct-flyash> ;
    edge:materialQuantity "1200.0"^^xsd:decimal ;  # 1,200 m³
    edge:materialEmissions "378000.0"^^xsd:decimal ; # 1,200 × 315 kgCO2e/m³
    edge:materialPercentageOfTotal "22.1"^^xsd:decimal ;
    edge:lifecycleStage "A1-A3" ;
    rdfs:comment "Project uses blended cement concrete with 30% fly ash replacement, reducing embodied carbon by ~29% vs. baseline." .

# Project: Recycled Steel Rebar (50% recycled content)
ex:ProjectSteel
    rdf:type edge:ProjectMaterialUsage ;
    edge:usesConstructionMaterial <http://tgo.or.th/materials/steel-rebar-recycled-50pct> ;
    edge:materialQuantity "180000.0"^^xsd:decimal ;  # 180 tonnes
    edge:materialEmissions "324000.0"^^xsd:decimal ; # 180,000 kg × 1.8 kgCO2e/kg
    edge:materialPercentageOfTotal "18.9"^^xsd:decimal ;
    edge:lifecycleStage "A1-A3" ;
    rdfs:comment "Project uses rebar with 50% recycled content, reducing embodied carbon by 40% vs. virgin steel." .

# Project: Autoclaved Aerated Concrete (AAC) blocks
ex:ProjectBlocks
    rdf:type edge:ProjectMaterialUsage ;
    edge:usesConstructionMaterial <http://tgo.or.th/materials/aac-block-lightweight> ;
    edge:materialQuantity "25000.0"^^xsd:decimal ;   # 25,000 blocks
    edge:materialEmissions "62500.0"^^xsd:decimal ;  # 25,000 × 2.5 kgCO2e/block
    edge:materialPercentageOfTotal "3.7"^^xsd:decimal ;
    edge:lifecycleStage "A1-A3" ;
    rdfs:comment "Project uses AAC blocks which are lighter and have 37.5% lower embodied carbon vs. standard concrete blocks." .

# Project: Low-E Coated Glass
ex:ProjectGlass
    rdf:type edge:ProjectMaterialUsage ;
    edge:usesConstructionMaterial <http://tgo.or.th/materials/glass-low-e-6mm> ;
    edge:materialQuantity "800.0"^^xsd:decimal ;     # 800 m²
    edge:materialEmissions "28000.0"^^xsd:decimal ;  # 800 × 35 kgCO2e/m²
    edge:materialPercentageOfTotal "1.6"^^xsd:decimal ;
    edge:lifecycleStage "A1-A3" ;
    rdfs:comment "Project uses Low-E glass which has slightly higher embodied carbon but provides significant operational energy savings." .

#
# Example TGO Material Definitions (referenced above)
# In practice, these would be loaded from the TGO database
#

<http://tgo.or.th/materials/concrete-c30-rmc>
    rdf:type tgo:Concrete ;
    rdfs:label "Ready-mixed Concrete C30"@en ;
    rdfs:label "คอนกรีตผสมเสร็จ C30"@th ;
    tgo:hasEmissionFactor "445.0"^^xsd:decimal ;
    tgo:hasUnit "kgCO2e/m³" ;
    tgo:category "Concrete" ;
    tgo:effectiveDate "2026-01-01"^^xsd:date ;
    tgo:dataQuality "Verified" ;
    tgo:geographicScope "Thailand" .

<http://tgo.or.th/materials/concrete-c30-blended-30pct-flyash>
    rdf:type tgo:Concrete ;
    rdfs:label "Blended Cement Concrete C30 (30% Fly Ash)"@en ;
    rdfs:label "คอนกรีตปูนซีเมนต์ผสม C30 (30% เถ้าลอย)"@th ;
    tgo:hasEmissionFactor "315.0"^^xsd:decimal ;
    tgo:hasUnit "kgCO2e/m³" ;
    tgo:category "Concrete" ;
    tgo:effectiveDate "2026-01-01"^^xsd:date ;
    tgo:dataQuality "Verified" ;
    tgo:geographicScope "Thailand" .

<http://tgo.or.th/materials/steel-rebar-sd40>
    rdf:type tgo:Steel ;
    rdfs:label "Steel Reinforcement Bar SD40"@en ;
    rdfs:label "เหล็กเสริม SD40"@th ;
    tgo:hasEmissionFactor "3.0"^^xsd:decimal ;
    tgo:hasUnit "kgCO2e/kg" ;
    tgo:category "Steel" ;
    tgo:effectiveDate "2026-01-01"^^xsd:date ;
    tgo:dataQuality "Verified" ;
    tgo:geographicScope "Thailand" .

<http://tgo.or.th/materials/steel-rebar-recycled-50pct>
    rdf:type tgo:Steel ;
    rdfs:label "Steel Rebar with 50% Recycled Content"@en ;
    rdfs:label "เหล็กเสริมรีไซเคิล 50%"@th ;
    tgo:hasEmissionFactor "1.8"^^xsd:decimal ;
    tgo:hasUnit "kgCO2e/kg" ;
    tgo:category "Steel" ;
    tgo:effectiveDate "2026-01-01"^^xsd:date ;
    tgo:dataQuality "Estimated" ;
    tgo:geographicScope "Thailand" .

<http://tgo.or.th/materials/concrete-block-standard>
    rdf:type tgo:Masonry ;
    rdfs:label "Standard Concrete Block"@en ;
    rdfs:label "บล็อกคอนกรีตมาตรฐาน"@th ;
    tgo:hasEmissionFactor "4.0"^^xsd:decimal ;
    tgo:hasUnit "kgCO2e/block" ;
    tgo:category "Masonry" ;
    tgo:effectiveDate "2026-01-01"^^xsd:date ;
    tgo:dataQuality "Verified" ;
    tgo:geographicScope "Thailand" .

<http://tgo.or.th/materials/aac-block-lightweight>
    rdf:type tgo:Masonry ;
    rdfs:label "Autoclaved Aerated Concrete (AAC) Block"@en ;
    rdfs:label "บล็อกคอนกรีตมวลเบา AAC"@th ;
    tgo:hasEmissionFactor "2.5"^^xsd:decimal ;
    tgo:hasUnit "kgCO2e/block" ;
    tgo:category "Masonry" ;
    tgo:effectiveDate "2026-01-01"^^xsd:date ;
    tgo:dataQuality "Verified" ;
    tgo:geographicScope "Thailand" .

<http://tgo.or.th/materials/glass-float-6mm>
    rdf:type tgo:Glass ;
    rdfs:label "Float Glass 6mm"@en ;
    rdfs:label "กระจกใส 6mm"@th ;
    tgo:hasEmissionFactor "30.0"^^xsd:decimal ;
    tgo:hasUnit "kgCO2e/m²" ;
    tgo:category "Glass" ;
    tgo:effectiveDate "2026-01-01"^^xsd:date ;
    tgo:dataQuality "Verified" ;
    tgo:geographicScope "Thailand" .

<http://tgo.or.th/materials/glass-low-e-6mm>
    rdf:type tgo:Glass ;
    rdfs:label "Low-E Coated Glass 6mm"@en ;
    rdfs:label "กระจกเคลือบ Low-E 6mm"@th ;
    tgo:hasEmissionFactor "35.0"^^xsd:decimal ;
    tgo:hasUnit "kgCO2e/m²" ;
    tgo:category "Glass" ;
    tgo:effectiveDate "2026-01-01"^^xsd:date ;
    tgo:dataQuality "Verified" ;
    tgo:geographicScope "Thailand" .

#
# SPARQL Queries to Validate This Example
#

# Query 1: Calculate total baseline emissions
# SELECT (SUM(?emissions) AS ?totalBaseline)
# WHERE {
#   ?usage rdf:type edge:BaselineMaterialUsage ;
#          edge:materialEmissions ?emissions .
# }
# Expected result: 1,198,000 kgCO2e

# Query 2: Calculate total project emissions
# SELECT (SUM(?emissions) AS ?totalProject)
# WHERE {
#   ?usage rdf:type edge:ProjectMaterialUsage ;
#          edge:materialEmissions ?emissions .
# }
# Expected result: 792,500 kgCO2e

# Query 3: Verify carbon savings percentage
# SELECT ?project ?baselineEmissions ?projectEmissions ?savingsPercentage ?status
# WHERE {
#   ?project edge:hasCarbonAssessment ?assessment .
#   ?assessment edge:baselineEmissions ?baselineEmissions ;
#               edge:projectEmissions ?projectEmissions ;
#               edge:carbonSavingsPercentage ?savingsPercentage ;
#               edge:complianceStatus ?status .
# }
# Expected: 33.8% savings, status = PASS

#
# End of Example
#
