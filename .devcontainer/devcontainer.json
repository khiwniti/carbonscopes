{
  "name": "CarbonScope Dev",
  "forwardPorts": [3000, 8000, 5432, 6379],
  "portsAttributes": {
    "3000": {
      "label": "Frontend",
      "onAutoForward": "openBrowser",
      "visibility": "public"
    },
    "8000": {
      "label": "Backend API",
      "onAutoForward": "notify",
      "visibility": "public"
    }
  },
  "postStartCommand": "cd /workspaces/carbonscopes && bash -c 'mkdir -p /workspaces/.pnpm-store && echo Codespace ready'"
}
