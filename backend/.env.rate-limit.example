# Rate Limiting Configuration
# Add these to your .env file to customize rate limits

# Authentication endpoints (magic link, OTP)
# Format: {number}/{period} where period can be: second, minute, hour, day
# Default: 5 requests per 15 minutes
AUTH_RATE_LIMIT="5/15minutes"

# API key creation endpoint
# Default: 5 requests per 15 minutes
API_KEY_RATE_LIMIT="5/15minutes"

# Default rate limit for other endpoints (if rate limiting is applied)
# Default: 100 requests per minute
DEFAULT_RATE_LIMIT="100/minute"

# Redis configuration for distributed rate limiting
# If not set, falls back to in-memory storage (not suitable for production with multiple instances)
# UPSTASH_REDIS_REST_URL="https://your-redis-url"
# or
# REDIS_URL="redis://localhost:6379"
